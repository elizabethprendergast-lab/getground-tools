function toggleExportSelectMode() {
  if (!State.blocks.length) { toast('No blocks to export'); return; }
  if (State.exportMode) {
    exitExportSelectMode();
  } else {
    enterExportSelectMode();
  }
}
function enterExportSelectMode() {
  State.exportMode = true;
  State.exportSelectedIds = [];
  State.selectedId = null;
  document.getElementById('btn-block-export').classList.add('primary');
  renderCanvas();
  renderInspector();
  refreshExportBar();
  toast('Click sections to select. Click Copy HTML when ready.');
}
function exitExportSelectMode() {
  State.exportMode = false;
  State.exportSelectedIds = [];
  document.getElementById('btn-block-export').classList.remove('primary');
  renderCanvas();
  refreshExportBar();
}
function toggleExportSelected(id) {
  const idx = State.exportSelectedIds.indexOf(id);
  if (idx >= 0) State.exportSelectedIds.splice(idx, 1);
  else State.exportSelectedIds.push(id);
  renderCanvas();
  refreshExportBar();
}
function refreshExportBar() {
  const bar = document.getElementById('export-bar');
  const count = document.getElementById('ex-count');
  const copy = document.getElementById('ex-copy');
  if (!bar) return;
  bar.classList.toggle('open', !!State.exportMode);
  const n = State.exportSelectedIds.length;
  count.textContent = `${n} selected`;
  copy.disabled = n === 0;
}
function copyExportSelection() {
  const ids = State.exportSelectedIds;
  if (!ids.length) return;
  // Preserve canvas order
  const ordered = State.blocks.filter(b => ids.includes(b.id));
  const html = ordered.map(b => renderBlockForExport(b)).join('\n\n');
  navigator.clipboard.writeText(html).then(() => toast(`Copied ${ids.length} block${ids.length>1?'s':''}`));
}

