/* --------- Helpers --------- */
function uid() { return Math.random().toString(36).slice(2, 10); }

// Recursively find a block (and its parent context) by ID
function findBlock(id, blocks = State.blocks, parent = null) {
  for (let i = 0; i < blocks.length; i++) {
    const b = blocks[i];
    if (b.id === id) return { block: b, siblings: blocks, index: i, parent };
    if (b.children) {
      const found = findBlock(id, b.children, b);
      if (found) return found;
    }
  }
  return null;
}

// Render a block to HTML and inject data-block-id on its outer <td>
function renderBlockToHtml(block) {
  const html = BlockTypes[block.type].render(block);
  return html.replace(/<td(\s|>)/i, `<td data-block-id="${block.id}"$1`);
}

// Friendly label for a block (uses section.name when set)
function blockLabel(b) {
  if (b.type === 'section' && b.name && b.name.trim()) return b.name.trim();
  return BlockTypes[b.type] ? BlockTypes[b.type].label : b.type;
}

// Short preview text for a block (for the per-block HTML list)
function blockPreviewText(b) {
  if (b.type === 'section' && Array.isArray(b.children)) {
    // Try first heading or text child
    for (const c of b.children) {
      if (c.type === 'heading' && c.text) return c.text.slice(0, 60);
      if (c.type === 'text' && c.text) return c.text.slice(0, 60);
    }
    const n = b.children.length;
    return `${n} block${n === 1 ? '' : 's'} grouped`;
  }
  return ((b.heading || b.text || b.url || '') + '').slice(0, 60);
}

// Inline markdown: **bold**, *italic*, and [fs=Npx]...[/fs] for inline font size
function md(text) {
  let s = esc(text);
  s = s.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  s = s.replace(/(^|[^*])\*([^*\n]+?)\*(?!\*)/g, '$1<em>$2</em>');
  // Defensive: clicking A+/A- multiple times can stack [fs=N] markers (e.g.
  // [fs=14][fs=16][fs=12]Text[/fs][/fs][/fs]). Collapse consecutive openings
  // to keep only the LAST size, and consecutive closings to keep one.
  s = s.replace(/(\[fs=\d+\]){2,}/g, m => {
    const last = m.match(/\[fs=\d+\]/g);
    return last[last.length - 1];
  });
  s = s.replace(/(\[\/fs\]){2,}/g, '[/fs]');
  // Inline font size markers (added by the size buttons in the floating toolbar)
  s = s.replace(/\[fs=(\d+)\]([\s\S]*?)\[\/fs\]/g, '<span style="font-size:$1px;line-height:1.4;">$2</span>');
  // Strip any orphaned/unpaired size markers so they never show as literal text
  s = s.replace(/\[\/?fs(?:=\d+)?\]/g, '');
  // Inline links [label](url) → underlined accent-coloured anchor
  s = s.replace(/\[([^\]]+)\]\(([^)\s]+)\)/g, (m, label, url) =>
    `<a href="${url}" style="color:inherit;text-decoration:underline;">${label}</a>`);
  return s;
}
function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function mkBlock(type, overrides={}) {
  const def = BlockTypes[type];
  return { id: uid(), type, ...def.defaults(), ...overrides };
}
function mso(url, text, bg, color, fontSize, editKey) {
  const safeText = esc(text);
  const richText = md(text); // honours inline size ([fs=N]) + bold so toolbar edits persist
  const fs = fontSize || 14;
  // editKey (optional) lets the button text be inline-editable on canvas.
  // When set, the modern (non-Outlook) HTML wraps the text in a span the
  // canvas click handler picks up. The VML version (Outlook) stays plain.
  const editAttr = editKey ? ` data-edit="${editKey}"` : '';
  return `
    <!--[if mso]>
    <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word" href="${url}" style="height:48px;v-text-anchor:middle;width:220px;" arcsize="20%" stroke="f" fillcolor="${bg}">
      <w:anchorlock/><center style="color:${color};font-family:Arial,sans-serif;font-size:${fs}px;font-weight:bold;">${safeText}</center>
    </v:roundrect>
    <![endif]-->
    <!--[if !mso]><!-- -->
    <a href="${url}" style="background:${bg};color:${color};font-size:${fs}px;font-weight:700;padding:14px 28px;border-radius:10px;display:inline-block;letter-spacing:-0.005em;text-decoration:none;font-family:${State.brand.font};"><span${editAttr}>${richText}</span></a>
    <!--<![endif]-->`;
}

function applyUtm(url) {
  if (!url || !url.startsWith('http')) return url;
  const u = State.settings.utm;
  if (!u.source && !u.medium && !u.campaign) return url;
  try {
    const link = new URL(url);
    if (u.source) link.searchParams.set('utm_source', u.source);
    if (u.medium) link.searchParams.set('utm_medium', u.medium);
    if (u.campaign) link.searchParams.set('utm_campaign', u.campaign);
    return link.toString();
  } catch { return url; }
}

/* --------- Saved emails (multi-doc) --------- */
const SAVED_KEY = 'gg_saved_emails';

function getSavedEmails() {
  try { return JSON.parse(localStorage.getItem(SAVED_KEY) || '[]'); }
  catch { return []; }
}
function writeSavedEmails(list) { localStorage.setItem(SAVED_KEY, JSON.stringify(list)); }

function saveCurrentAs(name) {
  if (!name) return;
  const list = getSavedEmails();
  const entry = {
    id: uid(),
    name: name.trim(),
    savedAt: Date.now(),
    blocks: JSON.parse(JSON.stringify(State.blocks)),
    brandProfile: State.brandProfile,
    spacing: State.spacing,
    emailWidth: State.emailWidth
  };
  list.unshift(entry);
  writeSavedEmails(list);
  toast(`Saved "${entry.name}"`);
  return entry;
}

function loadSaved(id) {
  const e = getSavedEmails().find(x => x.id === id);
  if (!e) { toast('Email not found'); return; }
  if (State.blocks.length && !confirm(`Load "${e.name}"? This replaces what is on the canvas.`)) return;
  State.blocks = JSON.parse(JSON.stringify(e.blocks));
  if (e.brandProfile) State.brandProfile = e.brandProfile;
  if (e.spacing) State.spacing = e.spacing;
  if (e.emailWidth) State.emailWidth = e.emailWidth;
  State.selectedId = null;
  save();
  applyEmailWidth();
  renderCanvas(); renderInspector(); renderSide();
  toast(`Loaded "${e.name}"`);
}
function renameSaved(id) {
  const list = getSavedEmails();
  const e = list.find(x => x.id === id);
  if (!e) return;
  const n = prompt('Rename email:', e.name);
  if (!n || !n.trim()) return;
  e.name = n.trim();
  writeSavedEmails(list);
  renderSide();
}
function deleteSaved(id) {
  const e = getSavedEmails().find(x => x.id === id);
  if (!e) return;
  if (!confirm(`Delete "${e.name}"? This cannot be undone.`)) return;
  writeSavedEmails(getSavedEmails().filter(x => x.id !== id));
  renderSide();
  toast('Deleted');
}
function overwriteSaved(id) {
  const list = getSavedEmails();
  const e = list.find(x => x.id === id);
  if (!e) return;
  if (!confirm(`Overwrite "${e.name}" with the current canvas?`)) return;
  e.blocks = JSON.parse(JSON.stringify(State.blocks));
  e.brandProfile = State.brandProfile;
  e.spacing = State.spacing;
  e.emailWidth = State.emailWidth;
  e.savedAt = Date.now();
  writeSavedEmails(list);
  renderSide();
  toast(`Updated "${e.name}"`);
}

