/* --------- Background helpers (used by block definitions) --------- */

// Returns a CSS background declaration. If gradient colours are both set,
// outputs solid fallback (for Outlook) plus a linear-gradient (for modern clients).
function bgStyle(b, fallback) {
  const from = b.gradFrom;
  const to = b.gradTo;
  if (from && to) {
    const stop = b.gradStop != null ? b.gradStop : 100;
    const angle = b.gradAngle != null ? b.gradAngle : 180;
    // Outlook ignores background-image but honours background-color.
    // We put the start colour as the solid fallback so Outlook sees a clean
    // brand colour rather than white. Modern clients see the linear-gradient.
    return `background:${from};background-image:linear-gradient(${angle}deg, ${from} 0%, ${to} ${stop}%);`;
  }
  return `background:${b.bg || fallback || '#FFFFFF'};`;
}

// VML rect with gradient fill — gives Outlook desktop a real gradient
// rather than a solid fallback. Width is the email width; height is auto.
// Returns { open, close } HTML strings, or null if no gradient is configured.
function vmlGradient(b, widthPx) {
  if (!b || !b.gradFrom || !b.gradTo) return null;
  // VML angles run the opposite direction to CSS (0deg = bottom→top in VML,
  // 0deg = bottom→top-of-element in CSS modern). We invert to keep them visually aligned.
  const cssAngle = b.gradAngle != null ? b.gradAngle : 180;
  const vmlAngle = (cssAngle + 180) % 360;
  const w = widthPx || 600;
  return {
    open: `<!--[if mso | IE]><v:rect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word" fill="true" stroke="false" style="mso-width-percent:1000;width:${w}px;"><v:fill type="gradient" color="${b.gradFrom}" color2="${b.gradTo}" angle="${vmlAngle}"/><v:textbox inset="0,0,0,0"><![endif]-->`,
    close: `<!--[if mso | IE]></v:textbox></v:rect><![endif]-->`
  };
}

