        Add block
      </button>
    </div>`;

  // Decorate every block (top-level AND nested children inside Sections)
  // Children of a Section render WITHOUT action buttons / outline so the
  // section behaves visually as a single big block. They are still selectable
  // (for inline edit + inspector field editing) but don't show chrome.
  function decorate(blocks, insideSection) {
    blocks.forEach(block => {
      const td = canvas.querySelector(`td[data-block-id="${block.id}"]`);
      if (!td) return;
      if (insideSection) {
        // Children of sections now get their own action buttons (lightweight)
        // so they can be duplicated, copied, or deleted individually.
        td.classList.add('canvas-block', 'in-section');
        if (block.id === State.selectedId) td.classList.add('selected');
        td.style.position = 'relative';
        td.insertAdjacentHTML('afterbegin', `
          <div class="block-actions in-section-actions">
            <button data-act="up" title="Move up"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l7-7 7 7"/></svg></button>
            <button data-act="down" title="Move down"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12l-7 7-7-7"/></svg></button>
            <button data-act="dup" title="Duplicate"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button>
            <button data-act="copy" title="Copy HTML"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/><rect x="9" y="2" width="6" height="4" rx="1"/><path d="M9 14l2 2 4-4"/></svg></button>
            <button data-act="del" class="danger" title="Delete"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg></button>
          </div>`);
      } else {
        td.classList.add('canvas-block');
        if (block.id === State.selectedId) td.classList.add('selected');
        const isSection = block.type === 'section';
        if (isSection) td.classList.add('canvas-section');
        if (State.exportMode && State.exportSelectedIds.includes(block.id)) {
          td.classList.add('export-selected');
        }
        td.style.position = 'relative';
        // Up/down arrows are hidden for sections (per user request).
        const upDown = isSection ? '' : `
            <button data-act="up" title="Move up"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l7-7 7 7"/></svg></button>
            <button data-act="down" title="Move down"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12l-7 7-7-7"/></svg></button>`;
        // Section label badge (shown when section has a name, or always in export mode)
        const labelText = (isSection && block.name) ? block.name : blockLabel(block);
        const showLabel = (isSection && block.name) || State.exportMode;
        const nameBadge = showLabel ? `<div class="section-label">${esc(labelText)}</div>` : '';
        const tick = (State.exportMode && State.exportSelectedIds.includes(block.id))
          ? `<div class="export-tick">✓</div>` : '';
        td.insertAdjacentHTML('afterbegin', `
          ${nameBadge}
          ${tick}
          <div class="block-actions">
            <button class="drag-handle" draggable="true" title="Drag to move"><svg viewBox="0 0 24 24" fill="currentColor"><circle cx="9" cy="6" r="1.5"/><circle cx="15" cy="6" r="1.5"/><circle cx="9" cy="12" r="1.5"/><circle cx="15" cy="12" r="1.5"/><circle cx="9" cy="18" r="1.5"/><circle cx="15" cy="18" r="1.5"/></svg></button>
            ${upDown}
            <button data-act="dup" title="Duplicate"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button>
            <button data-act="copy" title="Copy HTML"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/><rect x="9" y="2" width="6" height="4" rx="1"/><path d="M9 14l2 2 4-4"/></svg></button>
            <button data-act="del" class="danger" title="Delete"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg></button>
          </div>`);
      }
      if (block.children) decorate(block.children, block.type === 'section' || insideSection);
    });
  }
  decorate(State.blocks, false);

  // Wire bottom "Add block" button
  const addEnd = document.getElementById('add-end');
  if (addEnd) addEnd.addEventListener('click', e => openAddPop(e.currentTarget, State.blocks.length));

  // Restore scroll position so the canvas does not jump on every edit.
  if (canvasWrap && savedScroll) {
    canvasWrap.scrollTop = savedScroll;
  }
}

/* --------- Quick-add popover --------- */
let pendingInsertIdx = null;
function openAddPop(anchor, idx) {
  pendingInsertIdx = idx;
  const bg = document.getElementById('add-pop-bg');
  const pop = document.getElementById('add-pop');
  const grid = document.getElementById('add-pop-grid');

  grid.innerHTML = Object.entries(BlockTypes)
    .filter(([k]) => k !== 'rawhtml')
    .map(([k, def]) => `
      <button class="add-pop-item" data-add="${k}">
        ${def.icon}<span>${def.label}</span>
      </button>`).join('');

  bg.classList.add('open');

  // Position the popover near the anchor
  const rect = anchor.getBoundingClientRect();
  const popW = 320;
  let left = rect.left + (rect.width / 2) - (popW / 2);
  let top = rect.bottom + 8;
  if (left < 8) left = 8;
  if (left + popW > window.innerWidth - 8) left = window.innerWidth - popW - 8;
  if (top + 280 > window.innerHeight) top = rect.top - 280;
  pop.style.left = left + 'px';
  pop.style.top = top + 'px';

  // Wire item clicks
  grid.querySelectorAll('[data-add]').forEach(b => {
    b.addEventListener('click', () => {
      addBlock(b.dataset.add, pendingInsertIdx);
      closeAddPop();
    });
  });
}
function closeAddPop() {
  document.getElementById('add-pop-bg').classList.remove('open');
  pendingInsertIdx = null;
}

