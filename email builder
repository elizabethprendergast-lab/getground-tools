function withBg(b, py, defaultBg, content) {
  const pt = b.padTop != null ? b.padTop : py;
  const pb = b.padBottom != null ? b.padBottom : py;
  const r = b.radius || 0;
  const hasBg = b.bg || (b.gradFrom && b.gradTo);
  if (r > 0 && hasBg) {
    let radiusCss;
    if (b.radiusPos === 'top') radiusCss = `border-radius:${r}px ${r}px 0 0;`;
    else if (b.radiusPos === 'bottom') radiusCss = `border-radius:0 0 ${r}px ${r}px;`;
    else if (b.radiusPos === 'none') radiusCss = '';
    else radiusCss = `border-radius:${r}px;`;
    return `
