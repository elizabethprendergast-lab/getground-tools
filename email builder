async function uploadToHubSpot(file) {
  // HubSpot Files API: POST /files/v3/files (multipart)
  const fd = new FormData();
  fd.append('file', file);
  fd.append('options', JSON.stringify({ access: 'PUBLIC_INDEXABLE' }));
  fd.append('folderPath', '/email-images');
  let res;
  try {
    res = await fetch('https://api.hubapi.com/files/v3/files', {
      method: 'POST',
      headers: { 'Authorization': 'Bearer ' + State.settings.hubspotToken },
      body: fd
    });
  } catch (err) {
    throw new Error('Network or CORS error: ' + (err && err.message ? err.message : err) + '. Browser blocked the request — try uploading the file manually in HubSpot Files instead.');
  }
  if (!res.ok) {
    let body = '';
    try { body = await res.text(); } catch {}
    throw new Error(`HubSpot ${res.status} ${res.statusText}. ${body.slice(0, 300)}`);
  }
  const data = await res.json();
  if (!data || !data.url) {
    throw new Error('HubSpot response did not include a URL. Raw: ' + JSON.stringify(data).slice(0, 300));
  }
  return data.url;
}

