    /* 2-column grid: stay 2-up on mobile (2x2) */
    .gg-grid-col { display: inline-block !important; width: 50% !important; box-sizing: border-box !important; padding: 6px 6px !important; }
    /* Icon cards: stack one on top of another on mobile */
    .gg-ic-cell { display: block !important; width: 100% !important; padding: 6px 0 !important; }
    .gg-ic-cell-empty { display: none !important; }
    /* Reassert hero alignment on mobile in case a client drops the inline style */
    .gg-hero-center, .gg-hero-center h1, .gg-hero-center p, .gg-hero-center div { text-align: center !important; }
    .gg-hero-left, .gg-hero-left h1, .gg-hero-left p { text-align: left !important; }
    .gg-hero-right, .gg-hero-right h1, .gg-hero-right p { text-align: right !important; }
    /* Paired buttons: stack with vertical gap */
    .gg-btn-pair { width: 100% !important; }
    .gg-btn-cell { display: block !important; padding: 0 0 12px 0 !important; }
    .gg-btn-cell:last-child { padding-bottom: 0 !important; }
    .gg-btn-cell a { display: block !important; text-align: center !important; }
  }
</style>`;

  const fullHtml = `${darkModeStyles}
<!-- Preheader -->
<div style="display:none;max-height:0;overflow:hidden;mso-hide:all;font-size:1px;line-height:1px;color:${cardBg};">
  &nbsp;
</div>

<div class="gg-page gg-body" style="width:100%;background:#FFFFFF;padding:0;font-family:${State.brand.font};color-scheme:light dark;supported-color-schemes:light dark;">
  <table role="presentation" class="gg-card" width="${w}" cellpadding="0" cellspacing="0" border="0" align="center" bgcolor="${cardBg}" style="max-width:${w}px;margin:0 auto;background:${cardBg};mso-color-alt:${cardBg};border-collapse:separate;font-family:${State.brand.font};color:${State.brand.dark};">
    ${tableHtml}
  </table>
</div>`;
  let out = stripCanvasAttrs(fullHtml);
  // Replace pure white BACKGROUNDS with brand-tinted near-white. Leaves text
  // colours alone (so white text on dark sections stays white).
  out = out.replace(/(background(?:-color)?\s*:\s*)#FFFFFF\b/gi, '$1' + cardBg);
  out = out.replace(/(background(?:-color)?\s*:\s*)#fff(?![0-9a-fA-F])/gi, '$1' + cardBg);
  // Add bgcolor attribute to every <td> that has an inline background colour
  // — needed so the dark-mode CSS attribute selectors above can match. We
  // also tag tds with a LIGHT background using the gg-light-bg class so dark
  // mode can flip ANY light colour (not just whitelisted hex codes).
  function luminance(hex) {
    if (hex.length === 4) hex = '#' + hex[1]+hex[1]+hex[2]+hex[2]+hex[3]+hex[3];
    const r = parseInt(hex.slice(1,3), 16);
    const g = parseInt(hex.slice(3,5), 16);
    const b = parseInt(hex.slice(5,7), 16);
    return (0.299*r + 0.587*g + 0.114*b) / 255;
  }
  out = out.replace(/<td(\s[^>]*?)style="([^"]*?)background(?:-color)?\s*:\s*(#[0-9a-fA-F]{3,8})([^"]*?)"/gi, (m, pre, styleStart, color, styleEnd) => {
    if (/\sbgcolor=/i.test(pre)) return m;
    let bg = color.toUpperCase();
    if (bg.length === 4) bg = '#' + bg[1]+bg[1]+bg[2]+bg[2]+bg[3]+bg[3];
    const isLight = luminance(bg) > 0.75;
    const lightClass = isLight ? ' class="gg-light-bg"' : '';
    // If the td already has a class attribute, append gg-light-bg into it
    if (isLight && /\sclass="/.test(pre)) {
      const newPre = pre.replace(/\sclass="([^"]*)"/, ' class="$1 gg-light-bg"');
      return `<td${newPre} bgcolor="${bg}" style="${styleStart}background:${color}${styleEnd}"`;
    }
    return `<td${pre}${lightClass} bgcolor="${bg}" style="${styleStart}background:${color}${styleEnd}"`;
  });
  // Also tag <table> elements with light backgrounds (gradient sections live
  // on a table, not a td). Same luminance check.
  out = out.replace(/<table(\s[^>]*?)style="([^"]*?)background(?:-color)?\s*:\s*(#[0-9a-fA-F]{3,8})([^"]*?)"/gi, (m, pre, styleStart, color, styleEnd) => {
    let bg = color.toUpperCase();
    if (bg.length === 4) bg = '#' + bg[1]+bg[1]+bg[2]+bg[2]+bg[3]+bg[3];
    const isLight = luminance(bg) > 0.75;
    if (!isLight) return m;
    if (/\sclass="/.test(pre)) {
      const newPre = pre.replace(/\sclass="([^"]*)"/, ' class="$1 gg-light-bg"');
      return `<table${newPre} style="${styleStart}background:${color}${styleEnd}"`;
    }
    return `<table${pre} class="gg-light-bg" style="${styleStart}background:${color}${styleEnd}"`;
  });
  return out;
}

