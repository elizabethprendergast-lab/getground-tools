/* --------- Inspector --------- */
// Fields per block type that are already inline-editable on the canvas.
// We hide these in the inspector so the panel stays focused on structural
// options (size, colour, alignment, padding, layout) rather than duplicating
// what you can click and type directly.
const INLINE_EDITABLE_FIELDS = {
  hero: ['eyebrow', 'heading', 'sub'],
  text: ['text'],
  heading: ['text'],
  quote: ['text'],
  pivot: ['text'],
  button: ['text'],
  buttonrow: ['primaryText', 'secondaryText'],
  imagetext: ['eyebrow', 'title', 'body'],
  pillarcard: ['number', 'heading', 'body', 'ctaText'],
  signoff: ['brand', 'tagline'],
  featurecards: [],
  featurerow: [],
  imagegrid: [],
  iconcards: [],
  stats: []
};

// Categorise inspector fields so the panel renders as a scannable, grouped
// set of small sections rather than a long flat list. Returns one of:
// 'text' | 'bg' | 'spacing' | 'button' | 'image' | 'link' | 'cards' | 'other'.
function categorizeField(key, blockType) {
  // For button-only blocks, keep button-specific stuff in one "Button" group,
  // but route container background / font size / padding to Advanced so the
  // top of the panel stays focused on URL + colours + alignment.
  if (blockType === 'button' || blockType === 'buttonrow') {
    if (/^(paddingY|marginY|bg)$/.test(key)) return 'spacing';
    return 'button';
  }
  if (/^(text|heading|body|eyebrow|sub|title|tagline|brand|name|number|label|stats|items)$/i.test(key)) return 'content';
  if (/^(bg|background|gradFrom|gradTo|gradStop|gradAngle)$/i.test(key)) return 'bg';
  // Any other colour-ish field (badge fill, borders, etc.) stays visible under Background
  if (/(Bg|Border)$/.test(key) || /^(border|badge|badgeBg)$/i.test(key)) return 'bg';
  if (/(Size|size|fontSize|align|color|Color|accent)$/i.test(key) || /^(align|size|fontSize|color)$/i.test(key)) return 'text';
  if (/^(padding|padTop|padBottom|margin|radius|gap|rowGap|spacing|btnGap)/i.test(key) || /^(paddingY|marginY|radius|radiusPos)$/i.test(key)) return 'spacing';
  if (/^btn|^primary|^secondary/i.test(key)) return 'button';
  if (/^(src|alt|img|imgWidth|imgPos|imgAlt|width|height|fullWidth)$/i.test(key)) return 'image';
  if (/^(url|link|linkText|linkUrl|link2|btnUrl|primaryUrl|secondaryUrl)$/i.test(key) || /Url$/i.test(key)) return 'link';
  return 'other';
}

// Display order + headings for each category. `advanced: true` means the
// group is hidden inside a collapsible "Advanced settings" expander, so
// non-designer users see a clean essentials-only view by default.
const FIELD_GROUPS = [
  { key: 'content', label: 'Content', advanced: false },
  { key: 'text', label: 'Text style', advanced: false },
  { key: 'bg', label: 'Background', advanced: false },
  { key: 'image', label: 'Image', advanced: false },
  { key: 'button', label: 'Button', advanced: false },
  { key: 'link', label: 'Links', advanced: false },
  { key: 'spacing', label: 'Spacing & shape', advanced: true },
  { key: 'other', label: 'Other', advanced: true }
];

function renderInspector() {
  const insp = document.getElementById('inspector');
  const f = State.selectedId ? findBlock(State.selectedId) : null;
  const block = f ? f.block : null;
  if (!block) {
    insp.innerHTML = `<p class="insp-empty">Select a block on the canvas to edit its style. Click any text to edit it inline.</p>`;
    return;
  }
  const def = BlockTypes[block.type];
  const isSection = block.type === 'section';

  // Breadcrumb showing where we are (Section > Child)
  const parent = f.parent;
  const sectionName = parent ? (parent.name || 'Section') : null;
  const breadcrumb = parent ? `
    <div class="insp-breadcrumb">
      <button class="insp-crumb" data-select-id="${parent.id}" title="Edit the parent section">
        ${esc(sectionName)}
      </button>
      <span class="insp-crumb-sep">›</span>
      <span class="insp-crumb-current">${def.label}</span>
    </div>` : '';

  // Filter out fields that are inline-editable on canvas — the inspector
  // should focus on structural / style options, not duplicate text inputs.
  const inlineFields = INLINE_EDITABLE_FIELDS[block.type] || [];
  const inspectorFields = def.fields.filter(field => !inlineFields.includes(field.key));

  // Group fields into named categories. Essentials (text, bg, image, button,
  // link, content) render visibly. Advanced (spacing, shape, other) collapse
  // into a "Show advanced" expander so the inspector reads as essentials-first.
  const grouped = {};
  inspectorFields.forEach(field => {
    const cat = categorizeField(field.key, block.type);
    (grouped[cat] = grouped[cat] || []).push(field);
  });
  const essentialHtml = FIELD_GROUPS.filter(g => !g.advanced).map(group => {
    const fields = grouped[group.key];
    if (!fields || !fields.length) return '';
    const groupHtml = fields.map(f => fieldRender(f, block[f.key])).join('');
    return `
      <div class="insp-group">
        <p class="insp-group-title">${group.label}</p>
        ${groupHtml}
      </div>`;
  }).join('');
  const advancedGroupsHtml = FIELD_GROUPS.filter(g => g.advanced).map(group => {
    const fields = grouped[group.key];
    if (!fields || !fields.length) return '';
    const groupHtml = fields.map(f => fieldRender(f, block[f.key])).join('');
    return `
      <div class="insp-group">
        <p class="insp-group-title">${group.label}</p>
        ${groupHtml}
      </div>`;
  }).join('');
  const advancedHtml = advancedGroupsHtml ? `
    <details class="insp-advanced">
      <summary><span class="insp-advanced-icon">⚙</span> Advanced settings</summary>
      <div class="insp-advanced-body">${advancedGroupsHtml}</div>
    </details>` : '';
  const fieldHtml = essentialHtml + advancedHtml;
  // Hint when content is edited inline
  const inlineHint = inlineFields.length ? `
    <p class="insp-tip">
      <span>Tip</span> Click text on the canvas to edit it directly.
    </p>` : '';

  const heroDownload = block.type === 'hero' ? `
    <div class="field" style="margin-top:14px;padding-top:14px;border-top:1px solid var(--gg-border)">
      <label style="margin-bottom:6px">Export</label>
      <button class="icon-btn" id="ins-download-png" type="button" style="width:100%;justify-content:center;background:var(--gg-dark);color:var(--gg-white);border:0;font-size:12px;height:34px">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
        Download hero as PNG
      </button>
      <p class="field-help" style="margin-top:6px">Saves the hero (gradient + text + button) as a PNG to your computer. Upload it to HubSpot Files manually if you want to use it as an image.</p>
    </div>` : '';

  insp.innerHTML = `
    ${breadcrumb}
    <h3 class="insp-h">${isSection ? 'Section' : def.label}</h3>
    ${inlineHint}
    ${fieldHtml}
    ${heroDownload}
    <div class="insp-actions">
      <button id="ins-export"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2M9 4h6v4H9z"/></svg> Block HTML</button>
      <button id="ins-dup"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg> Duplicate</button>
    </div>`;

  // Wire up breadcrumb clicks to jump to parent section
  insp.querySelectorAll('[data-select-id]').forEach(btn => {
    btn.addEventListener('click', () => selectBlock(btn.dataset.selectId));
  });

  // Wire up inputs (only for fields the inspector is actually showing)
  inspectorFields.forEach(f => wireField(f, block));
  document.getElementById('ins-export').addEventListener('click', () => {
    const html = renderBlockForExport(block);
    showHtmlModal(`${def.label} block HTML`, html);
  });
  document.getElementById('ins-dup').addEventListener('click', () => {
    duplicateBlock(block.id);
  });
  const dlBtn = document.getElementById('ins-download-png');
  if (dlBtn) dlBtn.addEventListener('click', async () => {
    toast('Capturing hero…');
    try {
      const blob = await snapshotBlockToBlob(block.id);
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `hero-${(block.heading || 'image').slice(0,30).replace(/[^a-z0-9]/gi,'-')}.png`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      setTimeout(() => URL.revokeObjectURL(url), 1000);
      toast('PNG downloaded ✓');
    } catch (err) {
      console.error('Hero capture failed:', err);
      alert('Could not capture hero:\n\n' + err.message);
    }
  });
}

function fieldRender(f, val) {
  if (f.type === 'text' || f.type === 'link') {
    return `<div class="field"><label>${f.label}</label><input type="text" data-fkey="${f.key}" value="${esc(val||'')}"></div>`;
  }
  if (f.type === 'textarea') {
    return `<div class="field"><label>${f.label}</label><textarea data-fkey="${f.key}">${esc(val||'')}</textarea></div>`;
  }
  if (f.type === 'color') {
    const display = val ? val : 'Default / unset';
    const labelClass = val ? '' : 'muted';
    return `<div class="field">
      <label>${f.label}</label>
      <button type="button" class="color-trigger" data-fkey="${f.key}" data-gradient="${f.gradient ? '1' : '0'}">
        <div class="color-trigger-swatch" style="background:${val || 'repeating-linear-gradient(45deg, #f4f4f4, #f4f4f4 4px, #fff 4px, #fff 8px)'}"></div>
        <span class="color-trigger-label ${labelClass}">${esc(display)}</span>
      </button>
    </div>`;
  }
  if (f.type === 'select') {
    return `<div class="field"><label>${f.label}</label><select data-fkey="${f.key}">${f.options.map(o => `<option value="${o}" ${String(val)===String(o)?'selected':''}>${o}</option>`).join('')}</select></div>`;
  }
  if (f.type === 'range') {
    const v = val != null ? val : (f.min || 0);
    return `<div class="field">
      <label>${f.label} <span style="float:right;color:var(--gg-muted)" data-rangeval="${f.key}">${v}</span></label>
      <input type="range" data-fkey="${f.key}" min="${f.min}" max="${f.max}" step="${f.step||1}" value="${v}" style="width:100%">
    </div>`;
  }
  if (f.type === 'pills') {
    return `<div class="field">
      <label>${f.label}</label>
      <div style="display:flex;gap:4px;flex-wrap:wrap">
        ${f.options.map(o => {
          const v = typeof o === 'object' ? o.value : o;
          const lab = typeof o === 'object' ? o.label : o;
          return `<button type="button" class="profile-pill ${String(val)===String(v)?'active':''}" data-pkey="${f.key}" data-pval="${v}" style="flex:1;font-size:11px;padding:6px 10px">${lab}</button>`;
        }).join('')}
      </div>
    </div>`;
  }
  if (f.type === 'list') {
    return `<div class="field"><label>${f.label}</label><textarea data-fkey="${f.key}" data-mode="list">${(val||[]).join('\n')}</textarea></div>`;
  }
  if (f.type === 'stats') {
    // Stat numbers and labels are edited inline on canvas. Inspector only
    // shows a compact list with Remove buttons + "+ Add stat".
    const items = val || [];
    return `<div class="field"><label>${f.label}</label>
      <p class="field-help" style="margin-bottom:8px">Click any number or label on the canvas to edit it.</p>
      ${items.map((s, i) => `
        <div style="display:flex;align-items:center;justify-content:space-between;border:1px solid var(--gg-border);border-radius:8px;padding:6px 10px;margin-bottom:6px;background:#FFFFFF;">
          <span style="font-size:12px;color:var(--gg-dark);font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;margin-right:8px;">${i+1}. ${esc(s.num || '')} <span style="color:var(--gg-muted);font-weight:400;">${esc(s.label || '')}</span></span>
          <button type="button" data-fkey="${f.key}-del-${i}" style="border:0;background:transparent;color:#B43A3A;cursor:pointer;font-size:11px;padding:0;">Remove</button>
        </div>`).join('')}
      <button type="button" data-fkey="${f.key}-add" style="width:100%;padding:8px;border:1px dashed var(--gg-border);border-radius:8px;background:var(--gg-surface);cursor:pointer;font-size:12px;color:var(--gg-dark);">+ Add stat</button>
    </div>`;
  }
  if (f.type === 'cards') {
    // Card text is edited inline on the canvas. Inspector only shows a tiny
    // row per card with a remove button, plus "+ Add card" at the bottom.
    // This keeps the inspector clean for sales users.
    const items = val || [];
    return `<div class="field"><label>${f.label}</label>
      <p class="field-help" style="margin-bottom:8px">Click any card text on the canvas to edit it.</p>
      ${items.map((it, i) => {
        const preview = (it.title || it.num || '').slice(0, 32) || `Card ${i+1}`;
        return `
        <div style="border:1px solid var(--gg-border);border-radius:8px;padding:6px 10px;margin-bottom:6px;background:#FFFFFF;">
          <div style="display:flex;align-items:center;justify-content:space-between;">
            <span style="font-size:12px;color:var(--gg-dark);font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;margin-right:8px;">${i+1}. ${esc(preview)}</span>
            <button type="button" data-fkey="${f.key}-del-${i}" style="border:0;background:transparent;color:#B43A3A;cursor:pointer;font-size:11px;padding:0;">Remove</button>
          </div>
          <input type="text" data-fkey="${f.key}-link-${i}" value="${esc(it.link||'')}" placeholder="Link URL (optional)" style="width:100%;margin-top:6px;padding:5px 8px;border:1px solid var(--gg-border);border-radius:6px;font-size:11px;box-sizing:border-box;">
        </div>`;
      }).join('')}
      <button type="button" data-fkey="${f.key}-add" style="width:100%;padding:8px;border:1px dashed var(--gg-border);border-radius:8px;background:var(--gg-surface);cursor:pointer;font-size:12px;color:var(--gg-dark);">+ Add card</button>
    </div>`;
  }
  if (f.type === 'disclaimers') {
    const selected = Array.isArray(val) ? val : [];
    const checks = Object.entries(Disclaimers).map(([key, d]) => `
      <label style="display:flex;align-items:flex-start;gap:8px;padding:8px 10px;border:1px solid var(--gg-border);border-radius:8px;margin-bottom:6px;cursor:pointer;background:${selected.includes(key)?'var(--gg-surface)':'#FFFFFF'};">
        <input type="checkbox" data-disc="${key}" ${selected.includes(key)?'checked':''} style="margin-top:2px;flex-shrink:0">
        <span style="font-size:12px;font-weight:600;color:var(--gg-dark);line-height:1.3">${d.label}</span>
      </label>`).join('');
    return `<div class="field">
      <label>${f.label}</label>
      <button class="icon-btn" data-disc-suggest type="button" style="width:100%;justify-content:center;border:1px solid var(--gg-border);margin-bottom:8px;font-size:11px">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l2.4 7.4H22l-6.2 4.5L18.2 22 12 17.5 5.8 22l2.4-8.1L2 9.4h7.6z"/></svg>
        Auto-suggest from email content
      </button>
      ${checks}
    </div>`;
  }
  if (f.type === 'image') {
    return `<div class="field">
      <label>${f.label}</label>
      ${val ? `<img src="${val}" class="img-preview">` : ''}
      <button class="icon-btn primary" data-fkey="${f.key}-open" type="button" style="width:100%;justify-content:center">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
        ${val ? 'Replace image' : 'Upload image'}
      </button>
      ${State.settings.hubspotToken
        ? '<p class="field-help">Auto-hosts to HubSpot Files.</p>'
        : '<p class="field-help">Add a HubSpot token in Settings to auto-host images.</p>'}
    </div>`;
  }
  return '';
}

function wireField(f, block) {
  if (f.type === 'text' || f.type === 'link' || f.type === 'textarea') {
    document.querySelector(`[data-fkey="${f.key}"]`).addEventListener('input', e => {
      block[f.key] = e.target.value;
      save(); renderCanvas();
    });
  }
  else if (f.type === 'color') {
    const btn = document.querySelector(`button.color-trigger[data-fkey="${f.key}"]`);
    if (btn) {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        showColorPopover(btn, block, f);
      });
    }
  }
  else if (f.type === 'select') {
    document.querySelector(`[data-fkey="${f.key}"]`).addEventListener('change', e => {
      const v = e.target.value;
      block[f.key] = isNaN(v) ? v : Number(v);
      save(); renderCanvas();
    });
  }
  else if (f.type === 'range') {
    const input = document.querySelector(`[data-fkey="${f.key}"]`);
    const display = document.querySelector(`[data-rangeval="${f.key}"]`);
    input.addEventListener('input', e => {
      const v = Number(e.target.value);
      block[f.key] = v;
      if (display) display.textContent = v;
      save(); renderCanvas();
    });
  }
  else if (f.type === 'pills') {
    document.querySelectorAll(`[data-pkey="${f.key}"]`).forEach(btn => {
      btn.addEventListener('click', () => {
        const v = btn.dataset.pval;
        block[f.key] = isNaN(v) ? v : Number(v);
        document.querySelectorAll(`[data-pkey="${f.key}"]`).forEach(x => x.classList.toggle('active', x === btn));
        save(); renderCanvas();
      });
    });
  }
  else if (f.type === 'list') {
    document.querySelector(`[data-fkey="${f.key}"]`).addEventListener('input', e => {
      block[f.key] = e.target.value.split('\n').filter(Boolean);
      save(); renderCanvas();
    });
  }
  else if (f.type === 'stats') {
    (block[f.key]||[]).forEach((s, i) => {
      const delEl = document.querySelector(`[data-fkey="${f.key}-del-${i}"]`);
      if (delEl) delEl.addEventListener('click', () => {
        block[f.key].splice(i, 1);
        save(); renderCanvas(); renderInspector();
      });
    });
    const addEl = document.querySelector(`[data-fkey="${f.key}-add"]`);
    if (addEl) addEl.addEventListener('click', () => {
      block[f.key] = block[f.key] || [];
      block[f.key].push({ num: 'New', label: 'Stat label' });
      save(); renderCanvas(); renderInspector();
    });
  }
  else if (f.type === 'cards') {
    (block[f.key]||[]).forEach((it, i) => {
      const tEl = document.querySelector(`[data-fkey="${f.key}-title-${i}"]`);
      const dEl = document.querySelector(`[data-fkey="${f.key}-desc-${i}"]`);
      const delEl = document.querySelector(`[data-fkey="${f.key}-del-${i}"]`);
      if (tEl) tEl.addEventListener('input', e => { it.title = e.target.value; save(); renderCanvas(); });
      if (dEl) dEl.addEventListener('input', e => { it.desc = e.target.value; save(); renderCanvas(); });
      const lEl = document.querySelector(`[data-fkey="${f.key}-link-${i}"]`);
      if (lEl) lEl.addEventListener('input', e => { it.link = e.target.value.trim(); save(); renderCanvas(); });
      if (delEl) delEl.addEventListener('click', () => {
        block[f.key].splice(i, 1);
        save(); renderCanvas(); renderInspector();
      });
    });
    const addEl = document.querySelector(`[data-fkey="${f.key}-add"]`);
    if (addEl) addEl.addEventListener('click', () => {
      block[f.key] = block[f.key] || [];
      block[f.key].push({ title: 'New card', desc: 'Description' });
      save(); renderCanvas(); renderInspector();
    });
  }
  else if (f.type === 'image') {
    const btn = document.querySelector(`[data-fkey="${f.key}-open"]`);
    if (btn) {
      btn.addEventListener('click', () => showImageUploadModal(block, f.key));
    }
    const rehost = document.querySelector(`[data-fkey="${f.key}-rehost"]`);
    if (rehost) {
      rehost.addEventListener('click', async () => {
        const dataUrl = block[f.key];
        if (!dataUrl || !dataUrl.startsWith('data:')) return;
        toast('Converting and uploading…');
        try {
          const file = dataUrlToFile(dataUrl, 'image-' + Date.now());
          const url = await uploadToHubSpot(file);
          block[f.key] = url;
          save(); renderCanvas(); renderInspector();
          toast('Hosted on HubSpot ✓');
        } catch (err) {
          console.error('Re-host failed:', err);
          alert('Could not upload to HubSpot:\n\n' + err.message + '\n\nIf this is a CORS error, the builder running as a local file can not call HubSpot directly. Workaround: upload the original GIF in HubSpot UI (Marketing → Files), copy the URL, and paste it via "Replace image" → "Or paste hosted image URL".');
        }
      });
    }
  }
  else if (f.type === 'disclaimers') {
    document.querySelectorAll('[data-disc]').forEach(cb => {
      cb.addEventListener('change', e => {
        const key = e.target.dataset.disc;
        let cur = Array.isArray(block[f.key]) ? [...block[f.key]] : [];
        if (e.target.checked) {
          if (!cur.includes(key)) cur.push(key);
        } else {
          cur = cur.filter(k => k !== key);
        }
        block[f.key] = cur;
        save(); renderCanvas(); renderInspector();
      });
    });
    const sBtn = document.querySelector('[data-disc-suggest]');
    if (sBtn) sBtn.addEventListener('click', () => autoSuggestDisclaimers(block, f.key));
  }
}

function showImageUploadModal(block, fieldKey) {
  const m = document.getElementById('modal');
  // Resolve nested paths like "items.0.img" so click-to-replace works on
  // images inside imagegrid / featurerow / imagetext cards.
  const path = String(fieldKey).split('.');
  let parent = block;
  for (let i = 0; i < path.length - 1; i++) {
    parent = parent[path[i]];
    if (parent == null) { toast('Image target not found'); return; }
  }
  const lastKey = path[path.length - 1];
  const currentValue = parent[lastKey];
  const isUrl = currentValue && /^https?:\/\//.test(currentValue);

  m.classList.add('upload-modal');
  const assets = getBrandAssets();
  const brandLib = assets.length ? `
    <div class="upload-or">Brand library</div>
    <div class="brand-lib-grid">
      ${assets.map((a, i) => `
        <button type="button" class="brand-lib-card" data-asset="${i}" title="${esc(a.name)}">
          <div class="brand-lib-thumb" style="background-image:url('${esc(a.url)}')"></div>
          <div class="brand-lib-name">${esc(a.name)}</div>
        </button>`).join('')}
    </div>
  ` : '';
  m.innerHTML = `
    <h2>Add image</h2>
    <p>Pick a brand asset, drop a file, paste from clipboard, click to choose, or paste a URL.</p>

    ${brandLib}

    <div class="upload-bigzone" id="big-dz" tabindex="0">
      <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
        <path d="M17 8l-5-5-5 5"/>
        <line x1="12" y1="3" x2="12" y2="15"/>
      </svg>
      <div class="ub-title">Drop image or GIF here</div>
      <div class="ub-sub">or click to browse · paste with Cmd+V / Ctrl+V</div>
      <input type="file" accept="image/png,image/jpeg,image/gif,image/webp,image/svg+xml,image/*" style="display:none" id="big-file">
    </div>

    <div class="upload-or">Or use a URL</div>
    <div style="display:flex; gap:8px;">
      <input type="text" id="big-url" placeholder="https://your-cdn.com/image.png" value="${isUrl ? esc(currentValue) : ''}" style="flex:1;padding:10px;border:1px solid var(--gg-border);border-radius:8px;font-size:13px">
      <button class="icon-btn primary" id="big-url-go">Use URL</button>
    </div>

    <div class="modal-actions">
      <button class="icon-btn" id="modal-close">Cancel</button>
    </div>`;
  document.getElementById('modal-bg').classList.add('open');

  const bigDz = document.getElementById('big-dz');
  const bigFile = document.getElementById('big-file');
  const bigUrl = document.getElementById('big-url');

  // Click to choose file
  bigDz.addEventListener('click', () => bigFile.click());

  // Drag handlers
  ['dragenter','dragover'].forEach(ev => {
    bigDz.addEventListener(ev, e => {
      e.preventDefault(); e.stopPropagation();
      bigDz.classList.add('dragover');
      if (e.dataTransfer) e.dataTransfer.dropEffect = 'copy';
    });
  });
  bigDz.addEventListener('dragleave', e => { e.stopPropagation(); bigDz.classList.remove('dragover'); });
  bigDz.addEventListener('drop', async e => {
    e.preventDefault(); e.stopPropagation();
    bigDz.classList.remove('dragover');
    const files = Array.from(e.dataTransfer.files || []);
    const f0 = files.find(ff => ff.type.startsWith('image/'));
    if (!f0) { toast('Please drop an image file'); return; }
    await handleImage(f0, block, fieldKey);
    closeImageModal();
  });

  // File input change
  bigFile.addEventListener('change', async e => {
    const f0 = e.target.files[0];
    if (f0) {
      await handleImage(f0, block, fieldKey);
      closeImageModal();
    }
  });

  // Paste inside modal
  const pasteHandler = async (e) => {
    const items = e.clipboardData && e.clipboardData.items;
    if (!items) return;
    for (const item of items) {
      if (item.type && item.type.startsWith('image/')) {
        e.preventDefault();
        const file = item.getAsFile();
        if (file) {
          await handleImage(file, block, fieldKey);
          closeImageModal();
        }
        return;
      }
    }
  };
  m.addEventListener('paste', pasteHandler);
  // Focus the dropzone so paste lands on the modal
  setTimeout(() => bigDz.focus(), 50);

  // Brand library cards
  m.querySelectorAll('.brand-lib-card').forEach(card => {
    card.addEventListener('click', () => {
      const idx = Number(card.dataset.asset);
      const asset = getBrandAssets()[idx];
      if (!asset) return;
      parent[lastKey] = asset.url;
      save(); renderCanvas(); renderInspector();
      closeImageModal();
      toast(`Added ${asset.name}`);
    });
  });

  // URL submit
  document.getElementById('big-url-go').onclick = () => {
    const v = bigUrl.value.trim();
    if (!v) { toast('Paste a URL first'); return; }
    parent[lastKey] = v;
    save(); renderCanvas(); renderInspector();
    closeImageModal();
    toast('URL added');
  };
  bigUrl.addEventListener('keydown', e => {
    if (e.key === 'Enter') { e.preventDefault(); document.getElementById('big-url-go').click(); }
  });

  document.getElementById('modal-close').onclick = closeImageModal;

  function closeImageModal() {
    m.classList.remove('upload-modal');
    m.removeEventListener('paste', pasteHandler);
    closeModal();
  }
}

function autoSuggestDisclaimers(block, key) {
  // Collect all visible text from the email blocks
  let allText = '';
  State.blocks.forEach(b => {
    Object.values(b).forEach(v => {
      if (typeof v === 'string') allText += ' ' + v;
      if (Array.isArray(v)) allText += ' ' + v.map(x => typeof x === 'string' ? x : (x.num + ' ' + x.label)).join(' ');
    });
  });
  const lower = allText.toLowerCase();

  // Always include 'general'
  const suggested = new Set(['general']);

  Object.entries(Disclaimers).forEach(([k, d]) => {
    if (k === 'general') return;
    if (d.keywords.some(kw => lower.includes(kw.toLowerCase()))) suggested.add(k);
  });

  block[key] = Array.from(suggested);
  save(); renderCanvas(); renderInspector();
  toast(`Suggested ${suggested.size} disclaimer${suggested.size>1?'s':''}`);
}

// Convert a base64 data URL into a File so we can re-upload it
function dataUrlToFile(dataUrl, filename) {
  const [header, b64] = dataUrl.split(',');
  const mimeMatch = (header || '').match(/data:([^;]+)/);
  const mime = mimeMatch ? mimeMatch[1] : 'application/octet-stream';
  const binary = atob(b64 || '');
  const bytes = new Uint8Array(binary.length);
  for (let i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);
  const ext = mime.split('/')[1] || 'bin';
  return new File([bytes], filename || `image.${ext}`, { type: mime });
}

async function handleImage(file, block, key) {
  const sizeMB = file.size / (1024 * 1024);
  const sizeKB = file.size / 1024;
  const isGif = file.type === 'image/gif';
  const hasToken = !!State.settings.hubspotToken;
  const hasZapier = !!State.settings.zapierUploadUrl;
  // Resolve nested path (e.g. "items.0.img") so uploads land in the right field
  const path = String(key).split('.');
  let target = block;
  for (let i = 0; i < path.length - 1; i++) {
    target = target[path[i]];
    if (target == null) { toast('Image target not found'); return; }
  }
  const lastKey = path[path.length - 1];

  // Hard limit: base64 embedding above 500KB blows up email HTML and HubSpot
  // refuses to save it. Force user to use HubSpot, Zapier, or a hosted URL for big files.
  if (!hasToken && !hasZapier && sizeMB > 0.5) {
    alert(
      `This ${isGif ? 'GIF' : 'image'} is ${sizeKB > 1024 ? sizeMB.toFixed(1)+'MB' : Math.round(sizeKB)+'KB'}, too large to embed safely (HubSpot will refuse to save the email).\n\nFix it one of these ways:\n\n1. Upload the file to HubSpot Files manually, copy the URL, and paste it into the "Or paste hosted image URL" field.\n\n2. Add a HubSpot private app token in Settings (with the files scope) and the builder will auto-upload from now on.\n\n3. Configure a Zapier upload webhook in Settings (see "Setup steps").\n\nFiles under 500KB can still embed without hosting.`
    );
    return;
  }

  // If we have HubSpot, upload there first to skip the base64 round-trip
  if (hasToken) {
    toast(`Uploading ${isGif ? 'GIF' : 'image'} to HubSpot…`);
    try {
      const url = await uploadToHubSpot(file);
      if (url) {
        target[lastKey] = url;
        save(); renderCanvas(); renderInspector();
        toast('Hosted on HubSpot ✓');
        return;
      }
    } catch (err) {
      console.error('HubSpot upload failed:', err);
      // Fall through to Zapier if configured
      if (!hasZapier && sizeMB > 0.5) {
        alert(
          'HubSpot upload failed:\n\n' + err.message +
          '\n\nWhat to try:\n• Verify the token has the "files" scope (no other scopes needed)\n• Try a fresh token in HubSpot → Settings → Private Apps\n• Or upload manually: HubSpot → Marketing → Files, copy the URL, and paste it into the image block here.\n\nThe error has been logged in the browser console (Cmd+Opt+J / Ctrl+Shift+J) for more detail.'
        );
        return;
      }
      toast('HubSpot failed, trying Zapier…');
    }
  }

  // Zapier fallback (or primary if no HubSpot token)
  if (hasZapier) {
    toast(`Uploading ${isGif ? 'GIF' : 'image'} via Zapier…`);
    try {
      const url = await uploadViaZapier(file);
      if (url) {
        target[lastKey] = url;
        save(); renderCanvas(); renderInspector();
        toast('Hosted via Zapier ✓');
        return;
      }
    } catch (err) {
      console.error('Zapier upload failed:', err);
      if (sizeMB > 0.5) {
        alert('Zapier upload failed:\n\n' + err.message + '\n\nCheck the webhook URL and Zap setup, or upload manually via HubSpot Files.');
        return;
      }
      toast('Zapier failed, embedded as base64');
    }
  }

  // Base64 fallback
  const reader = new FileReader();
  reader.onload = () => {
    try {
      target[lastKey] = reader.result;
      save(); renderCanvas(); renderInspector();
      toast(isGif ? 'GIF added (embedded)' : 'Image added (embedded)');
    } catch (err) {
      toast('File too large to embed. Add a HubSpot token or paste a URL.');
    }
  };
  reader.onerror = () => toast('Could not read file');
  reader.readAsDataURL(file);
}

// Upload via a user-configured Zapier webhook.
// Expects the Zap to: accept multipart/form-data with field "file", upload to
// HubSpot Files (or any host), and respond with JSON: { url: "https://..." }
async function uploadViaZapier(file) {
  const endpoint = State.settings.zapierUploadUrl;
  if (!endpoint) throw new Error('No Zapier upload webhook configured. Add one in Settings.');
  const fd = new FormData();
  fd.append('file', file);
  fd.append('filename', file.name || ('image-' + Date.now()));
  let res;
  try {
    res = await fetch(endpoint, { method: 'POST', body: fd });
  } catch (err) {
    throw new Error('Network or CORS error reaching Zapier: ' + (err && err.message ? err.message : err));
  }
  if (!res.ok) {
    let body = '';
    try { body = await res.text(); } catch {}
    throw new Error(`Zapier ${res.status} ${res.statusText}. ${body.slice(0, 300)}`);
  }
  // Zapier sometimes returns plain text. Try JSON first, then look for a URL substring.
  const raw = await res.text();
  try {
    const data = JSON.parse(raw);
    if (data && data.url) return data.url;
    if (data && data.file_url) return data.file_url;
  } catch {}
  const m = raw.match(/https?:\/\/[^\s"']+/);
  if (m) return m[0];
  throw new Error('Zapier response did not include a URL. Raw: ' + raw.slice(0, 300));
}

