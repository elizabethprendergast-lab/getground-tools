// Convert contenteditable HTML back to plain text with **markdown** for bold/italic and [fs=N] for size
function htmlToMarkdownText(html) {
  let s = html;
  // Strip junk wrappers from rich-paste sources (Google Docs, Word, Notion)
  s = s.replace(/<!--[\s\S]*?-->/g, '');
  s = s.replace(/<style[\s\S]*?<\/style>/gi, '');
  s = s.replace(/<script[\s\S]*?<\/script>/gi, '');
  // Preserve anchor links BEFORE we strip tags. Convert <a href="X">text</a>
  // back to [text](X) markdown so md() can re-render them on canvas + export.
  s = s.replace(/<a\s+[^>]*href="([^"]+)"[^>]*>([\s\S]*?)<\/a\s*>/gi, (m, url, label) => {
    const cleanLabel = label.replace(/<[^>]+>/g, '').trim();
    return cleanLabel ? `[${cleanLabel}](${url})` : '';
  });
  // Preserve font-size spans first (so they don't get stripped)
  s = s.replace(/<span\s+[^>]*style="[^"]*font-size:\s*(\d+)px[^"]*"[^>]*>/gi, '[fs=$1]');
  s = s.replace(/<\/span>/gi, '[/fs]');
  // Headings → bold (with bigger size for h1/h2)
  s = s.replace(/<h1[^>]*>([\s\S]*?)<\/h1\s*>/gi, '\n\n[fs=28]**$1**[/fs]\n\n');
  s = s.replace(/<h2[^>]*>([\s\S]*?)<\/h2\s*>/gi, '\n\n[fs=22]**$1**[/fs]\n\n');
  s = s.replace(/<h3[^>]*>([\s\S]*?)<\/h3\s*>/gi, '\n\n[fs=18]**$1**[/fs]\n\n');
  s = s.replace(/<h[4-6][^>]*>([\s\S]*?)<\/h[4-6]\s*>/gi, '\n\n**$1**\n\n');
  // Lists → bullet/numbered lines
  s = s.replace(/<li[^>]*>([\s\S]*?)<\/li\s*>/gi, '- $1\n');
  s = s.replace(/<\/?[uo]l[^>]*>/gi, '\n');
  // Blockquote → italic
  s = s.replace(/<blockquote[^>]*>([\s\S]*?)<\/blockquote\s*>/gi, '\n\n*$1*\n\n');
  // Paragraph closes become double newlines (paragraph break)
  s = s.replace(/<\/p\s*>/gi, '\n\n');
  s = s.replace(/<p[^>]*>/gi, '');
  // Div breaks become newlines
  s = s.replace(/<div><br\s*\/?><\/div>/gi, '\n');
  s = s.replace(/<\/div>\s*<div[^>]*>/gi, '\n');
  s = s.replace(/<div[^>]*>/gi, '\n');
  s = s.replace(/<\/div>/gi, '');
  // Br tags
  s = s.replace(/<br\s*\/?>/gi, '\n');
  // Bold/italic
  s = s.replace(/<\s*(b|strong)\s*>/gi, '**');
  s = s.replace(/<\s*\/\s*(b|strong)\s*>/gi, '**');
  s = s.replace(/<\s*(i|em)\s*>/gi, '*');
  s = s.replace(/<\s*\/\s*(i|em)\s*>/gi, '*');
  // Strip any remaining tags (including non-size spans)
  s = s.replace(/<[^>]+>/g, '');
  // Clean orphan [fs] markers that don't pair properly
  s = s.replace(/\[fs=(\d+)\]([^\[]*)\[\/fs\]\[\/fs\]/g, '[fs=$1]$2[/fs]');
  // Decode HTML entities
  const txt = document.createElement('textarea');
  txt.innerHTML = s;
  let result = txt.value;
  // Collapse 3+ newlines to 2 (single paragraph break) but PRESERVE double newlines
  result = result.replace(/\n{3,}/g, '\n\n');
  // Trim leading/trailing newlines but preserve internal spacing
  return result.replace(/^[\s\n]+|[\s\n]+$/g, '');
}

// Write the currently-open inline edit straight to the block model. Used by the
