}

/* --------- Undo / Redo --------- */
const History = { stack: [], index: -1, max: 100, suppress: false };

function snapshot() {
  return JSON.stringify({ blocks: State.blocks, selectedId: State.selectedId });
}
function restoreSnapshot(s) {
  const data = JSON.parse(s);
  State.blocks = data.blocks;
  State.selectedId = data.selectedId;
}
function commitHistory() {
  if (History.suppress) return;
  const snap = snapshot();
  // Drop redo states past current
  History.stack = History.stack.slice(0, History.index + 1);
  // Skip identical consecutive states
  if (History.stack.length && History.stack[History.stack.length - 1] === snap) return;
  History.stack.push(snap);
  if (History.stack.length > History.max + 1) History.stack.shift();
  History.index = History.stack.length - 1;
}
function undo() {
  if (History.index <= 0) { toast('Nothing to undo'); return; }
  History.index--;
  History.suppress = true;
  restoreSnapshot(History.stack[History.index]);
  // Persist to localStorage without re-committing history
  localStorage.setItem(STORAGE_KEY, JSON.stringify({
    blocks: State.blocks, brand: State.brand, settings: State.settings, brandProfile: State.brandProfile
  }));
  History.suppress = false;
  renderCanvas(); renderInspector();
  toast('Undone');
}
function redo() {
  if (History.index >= History.stack.length - 1) { toast('Nothing to redo'); return; }
  History.index++;
  History.suppress = true;
  restoreSnapshot(History.stack[History.index]);
  localStorage.setItem(STORAGE_KEY, JSON.stringify({
    blocks: State.blocks, brand: State.brand, settings: State.settings, brandProfile: State.brandProfile
  }));
  History.suppress = false;
  renderCanvas(); renderInspector();
  toast('Redone');
}
function load() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (!raw) return;
    const data = JSON.parse(raw);
    if (data.blocks) State.blocks = data.blocks;
    if (data.brand) Object.assign(State.brand, data.brand);
    if (data.settings) Object.assign(State.settings, data.settings);
    if (data.brandProfile) State.brandProfile = data.brandProfile;
    if (data.spacing) State.spacing = data.spacing;
    if (data.emailWidth) State.emailWidth = data.emailWidth;
  } catch {}
}

/* --------- Render canvas --------- */
function renderCanvas() {
  const canvas = document.getElementById('canvas');
  // Preserve scroll so the user does not get yanked to the top on every edit.
  const canvasWrap = document.querySelector('.canvas-wrap');
  const savedScroll = canvasWrap ? canvasWrap.scrollTop : 0;
  if (!State.blocks.length) {
    canvas.innerHTML = `
      <div class="empty-canvas">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#A3ECEE" stroke-width="1.5"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
        <h3>Build your first email</h3>
        <p>Start from a template, or pick blocks from the left sidebar.<br>Press <kbd>Cmd+D</kbd> to duplicate, <kbd>Delete</kbd> to remove, <kbd>Esc</kbd> to deselect.</p>
        <div class="canvas-foot" style="margin-top:28px;background:transparent">
          <button class="add-block-btn" id="add-first">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
            Add your first block
          </button>
        </div>
      </div>`;
    document.getElementById('add-first').addEventListener('click', e => openAddPop(e.currentTarget, 0));
    return;
  }

  const tableHtml = State.blocks.map(b => renderBlockToHtml(b)).join('');
  canvas.classList.toggle('export-mode', !!State.exportMode);
  canvas.innerHTML = `
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-collapse:separate;font-family:${State.brand.font};">
      ${tableHtml}
