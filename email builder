<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
<meta http-equiv="Pragma" content="no-cache">
<meta http-equiv="Expires" content="0">
<title>GetGround Email Builder</title>
<style>
  /* === Theme tokens === */
  :root {
    --gg-dark: #06363A;
    --gg-accent: #A3ECEE;
    --gg-surface: #F4FCFD;
    --gg-border: #D0E8EA;
    --gg-canvas: #EEF8F9;
    --gg-white: #FFFFFF;
    --gg-muted: #4A6361;
    --gg-shadow: 0 1px 2px rgba(6,54,58,0.04), 0 4px 12px rgba(6,54,58,0.06);
    --gg-shadow-lg: 0 4px 24px rgba(6,54,58,0.10);
    --gg-radius: 12px;
    --gg-radius-lg: 20px;
    --gg-font: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
  }

  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; height: 100%; }
  body {
    font-family: var(--gg-font);
    color: var(--gg-dark);
    background: var(--gg-canvas);
    font-size: 14px;
    line-height: 1.5;
    overflow: hidden;
  }
  button { font-family: inherit; cursor: pointer; }
  input, select, textarea { font-family: inherit; }

  /* === App shell === */
  .app {
    display: grid;
    grid-template-rows: 56px 1fr;
    height: 100vh;
  }
  .topbar {
    display: flex;
    align-items: center;
    padding: 0 20px;
    background: var(--gg-white);
    border-bottom: 1px solid var(--gg-border);
    gap: 16px;
  }
  .brand {
    display: flex; align-items: center; gap: 10px;
    font-weight: 700; font-size: 15px; color: var(--gg-dark);
  }
  .brand-mark {
    width: 28px; height: 28px; border-radius: 8px;
    background: var(--gg-dark); display: grid; place-items: center;
    color: var(--gg-accent); font-size: 14px; font-weight: 700;
  }
  .topbar-spacer { flex: 1; }
  .icon-btn {
    height: 36px; padding: 0 14px; border-radius: 10px;
    background: transparent; border: 1px solid transparent;
    color: var(--gg-dark); font-size: 13px; font-weight: 500;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .icon-btn:hover { background: var(--gg-surface); }
  .icon-btn.primary {
    background: var(--gg-dark); color: var(--gg-white);
    font-weight: 600;
  }
  .icon-btn.primary:hover { background: #0a4d52; }
  .icon-btn svg { width: 16px; height: 16px; }

  /* === Workspace === */
  .workspace {
    display: grid;
    grid-template-columns: 64px var(--side-w, 280px) 5px 1fr 5px var(--inspector-w, 320px);
    overflow: hidden;
    position: relative;
  }
  .resize-handle {
    width: 5px;
    cursor: col-resize;
    background: transparent;
    position: relative;
    z-index: 5;
    transition: background .15s;
  }
  .resize-handle::after {
    content: '';
    position: absolute;
    inset: 0 2px;
    background: var(--gg-border);
    opacity: 0;
    transition: opacity .15s;
  }
  .resize-handle:hover::after, .resize-handle.dragging::after { opacity: 1; }
  .resize-handle:hover, .resize-handle.dragging { background: var(--gg-surface); }
  body.resizing { cursor: col-resize !important; user-select: none; }
  /* Nav rail */
  .nav {
    background: var(--gg-white);
    border-right: 1px solid var(--gg-border);
    padding: 12px 0;
    display: flex; flex-direction: column; align-items: center; gap: 4px;
  }
  .nav-btn {
    width: 56px; min-height: 54px; border-radius: 10px;
    background: transparent; border: 0;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 3px;
    color: var(--gg-muted);
    transition: all .15s;
    cursor: pointer;
    padding: 6px 4px;
  }
  .nav-btn:hover { background: var(--gg-surface); color: var(--gg-dark); }
  .nav-btn.active { background: var(--gg-dark); color: var(--gg-accent); }
  .nav-btn svg { width: 18px; height: 18px; }
  .nav-btn .nav-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1;
  }

  /* Side panel */
  .side {
    background: var(--gg-white);
    border-right: 1px solid var(--gg-border);
    overflow-y: auto;
  }
  .side-section { padding: 18px 16px; border-bottom: 1px solid var(--gg-border); }
  .side-title {
    font-size: 11px; font-weight: 600; letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--gg-muted);
    margin: 0 0 12px 0;
  }
  .side-h { font-size: 14px; font-weight: 600; margin: 0 0 6px 0; }
  .side-sub { font-size: 12px; color: var(--gg-muted); margin: 0; }

  .block-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 8px;
  }
  .block-tile {
    background: var(--gg-surface);
    border: 1px solid var(--gg-border);
    border-radius: 10px;
    padding: 12px 8px;
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    cursor: grab;
    transition: all .12s;
    user-select: none;
  }
  .block-tile:hover { background: var(--gg-accent); border-color: var(--gg-dark); transform: translateY(-1px); box-shadow: var(--gg-shadow); }
  .block-tile:active { cursor: grabbing; transform: translateY(0); }
  .block-tile.dragging { opacity: 0.4; }
  .block-tile svg { width: 20px; height: 20px; color: var(--gg-dark); pointer-events: none; }
  .block-tile span { font-size: 11px; font-weight: 600; color: var(--gg-dark); pointer-events: none; text-align: center; line-height: 1.2; }
  .block-hint {
    font-size: 11px; color: var(--gg-muted); margin: 0 0 10px 0;
  }
  /* Categorised blocks panel */
  .block-search {
    width: 100%;
    padding: 8px 12px;
    border: 1px solid var(--gg-border);
    border-radius: 8px;
    font-size: 12px;
    color: var(--gg-dark);
    background: var(--gg-white);
    margin-bottom: 14px;
    box-sizing: border-box;
    font-family: inherit;
  }
  .block-search:focus { outline: none; border-color: var(--gg-dark); }
  .block-cat { margin-bottom: 18px; }
  .block-cat:last-child { margin-bottom: 0; }
  .block-cat-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gg-muted);
    margin: 0 0 8px 0;
  }

  /* Insert "+" between blocks */
  .insert-rail {
    height: 0;
    position: relative;
    z-index: 8;
  }
  .insert-rail-inner {
    position: absolute;
    inset: -10px 0;
    display: flex; align-items: center; justify-content: center;
    opacity: 0;
    transition: opacity .12s;
    pointer-events: none;
  }
  .insert-rail:hover .insert-rail-inner { opacity: 1; pointer-events: auto; }
  .insert-rail-inner::before {
    content: ''; position: absolute; left: 24px; right: 24px; top: 50%;
    height: 2px; background: var(--gg-accent); border-radius: 2px;
  }
  .insert-btn {
    position: relative; z-index: 1;
    width: 28px; height: 28px; border-radius: 999px;
    background: var(--gg-dark); color: var(--gg-white); border: 0;
    display: grid; place-items: center; cursor: pointer;
    box-shadow: 0 2px 8px rgba(6,54,58,0.25);
  }
  .insert-btn:hover { background: var(--gg-accent); color: var(--gg-dark); }
  .insert-btn svg { width: 14px; height: 14px; }
  .insert-rail.dragover .insert-rail-inner { opacity: 1; }
  .insert-rail.dragover .insert-rail-inner::before { height: 4px; background: var(--gg-dark); }

  /* Bottom "+ Add block" CTA on canvas */
  .canvas-foot {
    padding: 16px;
    background: #FFFFFF;
  }
  .add-block-btn {
    width: 100%; padding: 18px;
    background: var(--gg-surface);
    border: 2px dashed var(--gg-border);
    border-radius: 14px;
    color: var(--gg-muted);
    font-weight: 600; font-size: 13px;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    cursor: pointer;
    transition: all .12s;
  }
  .add-block-btn:hover {
    border-color: var(--gg-dark);
    background: var(--gg-accent);
    color: var(--gg-dark);
    border-style: solid;
  }
  .add-block-btn svg { width: 16px; height: 16px; }

  /* Quick-add popover */
  .add-pop-bg {
    position: fixed; inset: 0; z-index: 60;
    display: none;
  }
  .add-pop-bg.open { display: block; }
  .add-pop {
    position: absolute;
    background: var(--gg-white);
    border: 1px solid var(--gg-border);
    border-radius: 16px;
    padding: 12px;
    box-shadow: var(--gg-shadow-lg);
    width: 320px;
    max-width: 90vw;
  }
  .add-pop-title {
    font-size: 11px; font-weight: 600; letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--gg-muted);
    margin: 0 0 10px 4px;
  }
  .add-pop-grid {
    display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 6px;
  }
  .add-pop-item {
    background: var(--gg-surface); border: 1px solid var(--gg-border);
    border-radius: 10px; padding: 12px 6px;
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    cursor: pointer; font-size: 11px; font-weight: 600; color: var(--gg-dark);
  }
  .add-pop-item:hover { background: var(--gg-accent); border-color: var(--gg-dark); }
  .add-pop-item svg { width: 18px; height: 18px; }

  .template-list { display: flex; flex-direction: column; gap: 8px; }
  .template-card {
    background: var(--gg-surface);
    border: 1px solid var(--gg-border);
    border-radius: 10px;
    padding: 12px;
    cursor: pointer;
    transition: all .15s;
  }
  .template-card:hover { border-color: var(--gg-dark); background: var(--gg-white); }
  .template-card h4 { margin: 0 0 4px 0; font-size: 13px; font-weight: 600; }
  .template-card p { margin: 0; font-size: 12px; color: var(--gg-muted); }

  /* Canvas */
  .canvas-wrap {
    overflow-y: auto;
    overflow-x: auto;
    background: var(--gg-canvas);
    display: flex; justify-content: center; align-items: flex-start;
    padding: 16px;
  }
  .canvas-controls {
    position: absolute; top: 70px; left: 50%; transform: translateX(-50%);
    z-index: 10;
    background: var(--gg-white);
    border: 1px solid var(--gg-border);
    border-radius: 999px;
    padding: 4px;
    display: flex; gap: 2px;
    box-shadow: var(--gg-shadow);
  }
  .canvas-controls button {
    border: 0; background: transparent;
    padding: 6px 14px; border-radius: 999px;
    font-size: 12px; font-weight: 500; color: var(--gg-muted);
  }
  .canvas-controls button.active { background: var(--gg-dark); color: var(--gg-white); }

  .canvas {
    width: var(--email-w, 600px);
    flex-shrink: 0;
    background: var(--gg-white);
    border-radius: var(--gg-radius-lg);
    overflow: hidden;
    box-shadow: var(--gg-shadow-lg);
    min-height: 200px;
    transition: width .25s ease, box-shadow .15s, outline .15s;
    margin-top: 40px;
    outline: 3px solid transparent;
    outline-offset: 2px;
  }
  .canvas.mobile { width: 420px !important; }
  /* Mirror the exported email's mobile stacking so the mobile preview is accurate */
  .canvas.mobile .gg-ic-cell { display: block !important; width: 100% !important; padding: 6px 0 !important; }
  .canvas.mobile .gg-ic-cell-empty { display: none !important; }
  .canvas.mobile .gg-stack-img, .canvas.mobile .gg-stack-text { display: block !important; width: 100% !important; padding: 0 0 16px 0 !important; }
  .canvas.mobile .gg-stat-cell { display: block !important; width: 100% !important; padding: 0 0 24px 0 !important; }
  .canvas.mobile .gg-btn-cell { display: block !important; padding: 0 0 12px 0 !important; }
  .canvas.mobile .gg-hero-center, .canvas.mobile .gg-hero-center h1, .canvas.mobile .gg-hero-center p, .canvas.mobile .gg-hero-center div { text-align: center !important; }
  .canvas.dragging-over {
    outline-color: var(--gg-accent);
    box-shadow: 0 0 0 8px rgba(163,236,238,0.3), var(--gg-shadow-lg);
  }
  .canvas-wrap.dragging::before {
    content: 'Drop where you want it to land';
    position: absolute;
    top: 16px; left: 50%; transform: translateX(-50%);
    background: var(--gg-dark); color: var(--gg-white);
    padding: 8px 16px; border-radius: 999px;
    font-size: 12px; font-weight: 600;
    z-index: 20;
    pointer-events: none;
  }
  .canvas-wrap { position: relative; }

  /* Drop indicator line — shows where the block will land */
  #drop-indicator {
    position: fixed;
    height: 4px;
    background: var(--gg-dark);
    border-radius: 2px;
    box-shadow: 0 0 0 2px rgba(163, 236, 238, 0.6);
    z-index: 25;
    pointer-events: none;
    display: none;
    transition: top .08s ease;
  }
  #drop-indicator::before, #drop-indicator::after {
    content: '';
    position: absolute;
    top: 50%; transform: translateY(-50%);
    width: 10px; height: 10px;
    background: var(--gg-dark);
    border-radius: 999px;
  }
  #drop-indicator::before { left: -5px; }
  #drop-indicator::after { right: -5px; }

  /* Block on canvas */
  .canvas-block {
    position: relative;
    transition: outline 0.12s ease-out, box-shadow 0.18s ease-out;
  }
  .canvas-block:hover { outline: 2px solid var(--gg-accent); outline-offset: -2px; }
  .canvas-block.selected {
    outline: 2px solid var(--gg-dark);
    outline-offset: -2px;
    box-shadow: 0 0 0 1px rgba(6,54,58,0.08);
  }
  /* Sections get a thicker, more deliberate selection so they read as the
     container, not as the content inside. */
  .canvas-block.canvas-section.selected {
    outline: 3px solid var(--gg-dark);
    outline-offset: -3px;
    box-shadow: 0 0 0 1px rgba(6,54,58,0.15);
  }
  /* Blocks nested inside a Section get a softer dashed outline — clearly
     differentiates "I am editing a child" from "I am editing the section". */
  .canvas-block.in-section:hover { outline: 1px dashed var(--gg-accent); outline-offset: -2px; }
  .canvas-block.in-section.selected {
    outline: 2px dashed var(--gg-dark);
    outline-offset: -2px;
    background: rgba(163,236,238,0.06);
  }

  /* Smooth fade-in for action buttons */
  .block-actions {
    opacity: 0;
    transform: translateY(-2px);
    transition: opacity 0.14s ease-out, transform 0.14s ease-out;
  }
  .canvas-block:hover > .block-actions,
  .canvas-block.selected > .block-actions {
    opacity: 1;
    transform: translateY(0);
  }
  /* Click any image on canvas to replace it. Subtle hover affordance. */
  .canvas img[data-img-edit] {
    cursor: pointer;
    transition: opacity 0.12s ease-out, box-shadow 0.12s ease-out;
  }
  .canvas img[data-img-edit]:hover {
    opacity: 0.85;
    box-shadow: 0 0 0 2px var(--gg-accent);
  }
  /* Block entrance animation when adding new blocks */
  @keyframes gg-block-in {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .canvas-block.gg-just-added {
    animation: gg-block-in 0.22s ease-out;
  }

  /* Section name badge — shown top-left when a section has a name */
  .section-label {
    position: absolute;
    top: 8px;
    left: 8px;
    background: var(--gg-dark);
    color: var(--gg-accent);
    padding: 3px 8px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    z-index: 6;
    display: none;
    box-shadow: 0 2px 6px rgba(6,54,58,0.18);
  }
  .canvas-block.canvas-section:hover .section-label,
  .canvas-block.canvas-section.selected .section-label { display: inline-block; }

  /* Export-select mode — click sections/blocks to add to a copy selection */
  .canvas.export-mode .canvas-block { cursor: pointer; }
  .canvas.export-mode .canvas-block:not(.in-section):hover {
    outline: 2px solid var(--gg-accent);
    outline-offset: -2px;
  }
  .canvas.export-mode .canvas-block.export-selected:not(.in-section) {
    outline: 3px solid #06363A;
    outline-offset: -3px;
    box-shadow: inset 0 0 0 9999px rgba(163, 236, 238, 0.18);
  }
  .canvas.export-mode .canvas-block .block-actions { display: none !important; }
  .canvas.export-mode .canvas-block.canvas-section .section-label { display: inline-block; }
  .canvas.export-mode .canvas-block.canvas-section:not(.export-selected) .section-label {
    background: var(--gg-surface);
    color: var(--gg-dark);
    border: 1px solid var(--gg-border);
  }
  .canvas.export-mode .canvas-block.export-selected .export-tick {
    position: absolute;
    top: 8px; right: 8px;
    width: 28px; height: 28px;
    border-radius: 999px;
    background: #06363A;
    color: #A3ECEE;
    display: grid; place-items: center;
    font-size: 14px; font-weight: 700;
    z-index: 7;
    box-shadow: 0 2px 6px rgba(6,54,58,0.25);
  }
  /* Floating export bar */
  .export-bar {
    position: fixed;
    left: 50%;
    bottom: 24px;
    transform: translateX(-50%);
    display: none;
    align-items: center;
    gap: 10px;
    background: var(--gg-dark);
    color: var(--gg-white);
    padding: 10px 14px;
    border-radius: 12px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.18);
    z-index: 60;
    font-size: 13px;
  }
  .export-bar.open { display: flex; }
  .export-bar .count { font-weight: 600; min-width: 92px; }
  .export-bar button {
    height: 34px; padding: 0 14px;
    border-radius: 8px; border: 0;
    font-size: 13px; font-weight: 600;
    cursor: pointer;
  }
  .export-bar .ex-copy { background: var(--gg-accent); color: var(--gg-dark); }
  .export-bar .ex-copy:disabled { opacity: 0.4; cursor: default; }
  .export-bar .ex-cancel { background: transparent; color: var(--gg-white); border: 1px solid rgba(255,255,255,0.3); }

  /* Dark mode preview (toggled per canvas) */
  .canvas-wrap.dark-preview { background: #0d0d0d; }
  .canvas-wrap.dark-preview .canvas {
    filter: invert(0.92) hue-rotate(180deg);
    background: #1a1a1a;
  }
  .canvas-wrap.dark-preview .canvas img { filter: invert(1) hue-rotate(180deg); }

  .block-actions {
    position: absolute;
    top: 8px; right: 8px;
    display: none;
    gap: 4px;
    z-index: 5;
  }
  .canvas-block.selected .block-actions,
  .canvas-block:hover .block-actions { display: flex; }

  .block-actions button {
    width: 28px; height: 28px;
    border-radius: 8px;
    background: var(--gg-dark);
    color: var(--gg-white);
    border: 0;
    display: grid; place-items: center;
  }
  .block-actions button:hover { background: #0a4d52; }
  .block-actions button.danger { background: #B43A3A; }
  .block-actions button.drag-handle { cursor: grab; background: #06363A; }
  .block-actions button.drag-handle:active { cursor: grabbing; }
  .block-actions svg { width: 14px; height: 14px; }
  .canvas-block.moving { opacity: 0.35; }

  /* Smaller, less prominent action buttons on child blocks inside sections.
     Visible only on hover/select to avoid cluttering the canvas. */
  .block-actions.in-section-actions { gap: 2px; top: 4px; right: 4px; }
  .block-actions.in-section-actions button { width: 22px; height: 22px; border-radius: 6px; opacity: 0.92; }
  .block-actions.in-section-actions svg { width: 12px; height: 12px; }

  .empty-canvas {
    text-align: center; padding: 80px 24px;
    color: var(--gg-muted);
  }
  .empty-canvas h3 { margin: 14px 0 6px 0; color: var(--gg-dark); font-weight: 700; font-size: 20px; letter-spacing: -0.01em; }
  .empty-canvas p { margin: 0; font-size: 13px; line-height: 1.7; }
  .empty-canvas kbd {
    display: inline-block;
    background: var(--gg-surface);
    border: 1px solid var(--gg-border);
    border-radius: 4px;
    padding: 1px 6px;
    font-family: ui-monospace, Menlo, monospace;
    font-size: 11px;
    color: var(--gg-dark);
    margin: 0 2px;
  }

  .drop-indicator {
    height: 3px;
    background: var(--gg-dark);
    margin: 0;
  }

  /* Inspector */
  .inspector {
    background: var(--gg-white);
    border-left: 1px solid var(--gg-border);
    overflow-y: auto;
    padding: 18px 16px;
  }
  .insp-empty { color: var(--gg-muted); font-size: 13px; text-align: center; padding: 40px 16px; line-height: 1.6; }
  .insp-block-title {
    font-size: 11px; font-weight: 600; letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--gg-muted);
    margin: 0 0 4px 0;
  }
  .insp-block-title.is-section { color: var(--gg-dark); }
  .insp-h { font-size: 16px; font-weight: 600; margin: 0 0 12px 0; }

  /* Breadcrumb at top of inspector — shows path when a child is selected */
  .insp-breadcrumb {
    display: flex; align-items: center; gap: 6px;
    margin: -4px 0 12px 0;
    font-size: 11px;
    color: var(--gg-muted);
  }
  .insp-crumb {
    background: var(--gg-surface);
    border: 1px solid var(--gg-border);
    border-radius: 5px;
    padding: 3px 8px;
    color: var(--gg-dark);
    font-weight: 600;
    cursor: pointer;
    transition: background 0.12s ease-out;
    max-width: 140px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 11px;
  }
  .insp-crumb:hover { background: var(--gg-accent); }
  .insp-crumb-sep { color: var(--gg-muted); }
  .insp-crumb-current { color: var(--gg-dark); font-weight: 600; }

  /* Subtle tip card explaining inline editing */
  .insp-tip {
    background: var(--gg-surface);
    border: 1px solid var(--gg-border);
    border-radius: 8px;
    padding: 8px 10px;
    font-size: 11px;
    line-height: 1.5;
    color: var(--gg-dark);
    margin: 0 0 14px 0;
  }
  .insp-tip span {
    display: inline-block;
    background: var(--gg-dark);
    color: var(--gg-accent);
    border-radius: 4px;
    padding: 1px 6px;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-right: 6px;
    vertical-align: middle;
  }

  /* Field groups in the inspector */
  .insp-group {
    margin-bottom: 18px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--gg-border);
  }
  .insp-group:last-of-type {
    border-bottom: 0;
    padding-bottom: 0;
    margin-bottom: 6px;
  }
  .insp-group-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gg-muted);
    margin: 0 0 10px 0;
  }
  .insp-group .field { margin-bottom: 10px; }
  .insp-group .field:last-child { margin-bottom: 0; }

  /* Advanced settings expander — hides spacing/shape/other behind a toggle
     so non-designers see a clean essentials-first inspector. */
  .insp-advanced {
    margin-top: 18px;
    border-top: 1px solid var(--gg-border);
    padding-top: 14px;
  }
  .insp-advanced > summary {
    list-style: none;
    cursor: pointer;
    display: flex; align-items: center; gap: 8px;
    font-size: 12px;
    font-weight: 600;
    color: var(--gg-muted);
    padding: 6px 8px;
    border-radius: 8px;
    transition: background 0.12s ease-out, color 0.12s ease-out;
    user-select: none;
  }
  .insp-advanced > summary::-webkit-details-marker { display: none; }
  .insp-advanced > summary::before {
    content: '›';
    display: inline-block;
    transition: transform 0.16s ease-out;
    color: var(--gg-muted);
    font-weight: 700;
  }
  .insp-advanced[open] > summary::before { transform: rotate(90deg); }
  .insp-advanced > summary:hover { background: var(--gg-surface); color: var(--gg-dark); }
  .insp-advanced-icon { font-size: 13px; }
  .insp-advanced-body { padding-top: 10px; }
  .insp-advanced[open] .insp-group:last-of-type {
    border-bottom: 0;
    padding-bottom: 0;
    margin-bottom: 0;
  }
  /* Slightly smaller, tighter section heading */
  .insp-h { font-size: 18px; font-weight: 700; margin: 6px 0 14px 0; letter-spacing: -0.01em; }

  .field { margin-bottom: 14px; }
  .field label {
    display: block; font-size: 12px; font-weight: 500;
    color: var(--gg-muted); margin-bottom: 4px;
  }
  .field input[type="text"],
  .field input[type="url"],
  .field textarea,
  .field select {
    width: 100%; padding: 8px 10px;
    border: 1px solid var(--gg-border); border-radius: 8px;
    font-size: 13px; color: var(--gg-dark);
    background: var(--gg-white);
  }
  .field input:focus, .field textarea:focus, .field select:focus {
    outline: 0; border-color: var(--gg-dark);
  }
  .field textarea { min-height: 70px; resize: vertical; font-family: inherit; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  .field-color { display: flex; align-items: center; gap: 8px; }
  .field-color input[type="color"] {
    width: 36px; height: 36px; border: 1px solid var(--gg-border);
    border-radius: 8px; padding: 2px; cursor: pointer;
  }
  .field-help {
    font-size: 11px; color: var(--gg-muted);
    margin: 4px 0 0 0;
  }

  .insp-actions { display: flex; gap: 8px; margin-top: 16px; }
  .insp-actions button {
    flex: 1; padding: 8px;
    background: var(--gg-surface); border: 1px solid var(--gg-border);
    border-radius: 8px; font-size: 12px; color: var(--gg-dark);
    display: inline-flex; align-items: center; justify-content: center; gap: 6px;
  }
  .insp-actions button:hover { border-color: var(--gg-dark); }
  .insp-actions button svg { width: 13px; height: 13px; }

  /* Brand panel */
  .brand-preview {
    border: 1px solid var(--gg-border);
    border-radius: 10px;
    padding: 12px;
    margin-bottom: 12px;
    background: var(--gg-surface);
  }
  .brand-color-swatch {
    width: 100%; height: 32px; border-radius: 6px;
    border: 1px solid var(--gg-border);
    margin-bottom: 4px;
  }


  /* Modal */
  .modal-bg {
    position: fixed; inset: 0; background: rgba(6,54,58,0.4);
    display: none; place-items: center; z-index: 50;
  }
  .modal-bg.open { display: grid; }
  .modal {
    background: var(--gg-white); border-radius: 16px;
    padding: 28px; width: 480px; max-width: 90%;
    box-shadow: var(--gg-shadow-lg);
  }
  .modal h2 { margin: 0 0 8px 0; font-size: 18px; font-weight: 600; }
  .modal p { margin: 0 0 16px 0; color: var(--gg-muted); font-size: 13px; }
  .modal pre {
    background: var(--gg-canvas);
    padding: 12px; border-radius: 8px;
    font-size: 11px; line-height: 1.4;
    max-height: 280px; overflow: auto;
    white-space: pre-wrap; word-break: break-word;
  }
  .modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 16px; }

  /* Floating edit toolbar */
  .edit-toolbar {
    position: fixed;
    background: var(--gg-dark);
    color: #FFFFFF;
    padding: 4px;
    border-radius: 8px;
    display: none;
    gap: 2px;
    z-index: 60;
    box-shadow: 0 4px 14px rgba(6,54,58,0.35);
  }
  .edit-toolbar.open { display: flex; }
  .edit-toolbar button {
    background: transparent;
    border: 0;
    color: #FFFFFF;
    padding: 5px 10px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 13px;
    min-width: 28px;
    font-family: inherit;
  }
  .edit-toolbar button:hover { background: rgba(255,255,255,0.18); }
  .edit-toolbar-sep {
    display: inline-block;
    width: 1px;
    background: rgba(255,255,255,0.2);
    margin: 0 2px;
    align-self: stretch;
  }
  /* Custom size picker — uses preventDefault on mousedown so the contenteditable
     selection never collapses (which a native <select> would do). */
  .edit-size-picker { position: relative; display: inline-block; }
  .edit-size-picker > button {
    background: rgba(255,255,255,0.08);
    color: #FFFFFF;
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 4px;
    padding: 4px 8px;
    font-size: 12px;
    font-family: inherit;
    cursor: pointer;
    min-width: 64px;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 6px;
  }
  .edit-size-picker > button:hover { background: rgba(255,255,255,0.18); }
  .edit-size-picker .size-caret { font-size: 9px; opacity: 0.8; }
  .edit-size-menu {
    position: absolute;
    top: calc(100% + 4px);
    right: 0;
    background: var(--gg-dark);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 6px;
    padding: 4px;
    min-width: 80px;
    max-height: 220px;
    overflow-y: auto;
    display: none;
    z-index: 70;
    box-shadow: 0 6px 18px rgba(0,0,0,0.35);
  }
  .edit-size-menu.open { display: block; }
  .edit-size-menu button {
    display: block;
    width: 100%;
    background: transparent;
    color: #FFFFFF;
    border: 0;
    padding: 5px 10px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 12px;
    font-family: inherit;
    text-align: left;
  }
  .edit-size-menu button:hover { background: rgba(255,255,255,0.18); }
  .edit-size-menu button.active { background: var(--gg-accent); color: var(--gg-dark); font-weight: 700; }

  /* Toast */
  .toast {
    position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%);
    background: var(--gg-dark); color: var(--gg-white);
    padding: 10px 18px; border-radius: 999px;
    font-size: 13px; font-weight: 500;
    z-index: 100;
    opacity: 0; transition: opacity .2s;
    pointer-events: none;
  }
  .toast.show { opacity: 1; }

  /* Inspector image button */
  .img-preview {
    width: 100%; max-height: 160px; object-fit: cover;
    border-radius: 10px; margin-bottom: 8px;
    border: 1px solid var(--gg-border);
  }

  /* Preview modal — wide */
  .preview-modal { width: 760px !important; max-width: 95vw !important; padding: 20px !important; }
  .preview-modal .preview-frame {
    background: #EAF0F6;
    padding: 24px;
    border-radius: 12px;
    max-height: 70vh;
    overflow: auto;
  }
  .preview-modal .preview-tabs {
    display: flex; gap: 4px; margin-bottom: 12px;
  }
  .preview-modal .preview-tabs button {
    background: var(--gg-surface);
    border: 1px solid var(--gg-border);
    border-radius: 999px;
    padding: 6px 14px;
    font-size: 12px;
    font-weight: 500;
    color: var(--gg-muted);
    cursor: pointer;
  }
  .preview-modal .preview-tabs button.active {
    background: var(--gg-dark);
    color: var(--gg-white);
    border-color: var(--gg-dark);
  }

  /* Big upload modal drop zone */
  .upload-modal { width: 540px !important; max-width: 92vw !important; }
  .upload-bigzone {
    border: 2px dashed var(--gg-border);
    border-radius: 16px;
    padding: 48px 24px;
    text-align: center;
    cursor: pointer;
    background: var(--gg-canvas);
    color: var(--gg-muted);
    transition: all .15s;
    margin: 8px 0;
  }
  .upload-bigzone:hover {
    border-color: var(--gg-dark);
    background: var(--gg-surface);
  }
  .upload-bigzone.dragover {
    border-color: var(--gg-dark);
    background: var(--gg-accent);
    color: var(--gg-dark);
    border-style: solid;
  }
  .upload-bigzone svg {
    margin: 0 auto 12px auto;
    color: var(--gg-dark);
  }
  .upload-bigzone .ub-title {
    font-weight: 600; font-size: 16px; color: var(--gg-dark);
  }
  .upload-bigzone .ub-sub {
    font-size: 13px; color: var(--gg-muted); margin-top: 4px;
  }
  .upload-or {
    display: flex; align-items: center; gap: 12px;
    margin: 16px 0 12px 0;
    color: var(--gg-muted); font-size: 11px; font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase;
  }
  .upload-or::before, .upload-or::after {
    content: ''; flex: 1; height: 1px; background: var(--gg-border);
  }

  /* Brand asset library cards (inside image upload modal) */
  .brand-lib-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 8px;
  }
  .brand-lib-card {
    border: 1px solid var(--gg-border);
    border-radius: 10px;
    padding: 8px;
    background: var(--gg-white);
    cursor: pointer;
    transition: border-color .15s, transform .1s;
    text-align: left;
    font-family: inherit;
  }
  .brand-lib-card:hover {
    border-color: var(--gg-dark);
    transform: translateY(-1px);
  }
  .brand-lib-thumb {
    width: 100%;
    height: 64px;
    background: var(--gg-surface);
    border-radius: 6px;
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
  }
  .brand-lib-name {
    font-size: 11px;
    font-weight: 600;
    color: var(--gg-dark);
    margin-top: 6px;
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  /* Switch */
  .switch { display: flex; align-items: center; gap: 8px; }

  /* Swatches */
  .swatches {
    display: flex; flex-wrap: wrap; gap: 4px;
    margin: 6px 0 0 0;
  }
  .swatch {
    width: 22px; height: 22px; border-radius: 6px;
    border: 1px solid rgba(6, 54, 58, 0.15);
    cursor: pointer; padding: 0;
    transition: transform .1s, box-shadow .1s;
  }
  .swatch:hover { transform: scale(1.15); }
  .swatch.active { box-shadow: 0 0 0 2px var(--gg-dark); border-color: transparent; }
  .swatch-row { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 8px; }
  .swatch-group-label {
    font-size: 10px; font-weight: 600; letter-spacing: 0.05em;
    text-transform: uppercase; color: var(--gg-muted);
    margin: 8px 0 4px 0;
  }

  /* Color trigger button (opens popover) */
  .color-trigger {
    width: 100%;
    height: 36px;
    border: 1px solid var(--gg-border);
    border-radius: 8px;
    padding: 3px;
    cursor: pointer;
    display: flex;
    align-items: center;
    background: var(--gg-white);
    transition: border-color .12s;
  }
  .color-trigger:hover { border-color: var(--gg-dark); }
  .color-trigger-swatch {
    width: 28px; height: 28px;
    border-radius: 6px;
    border: 1px solid rgba(0,0,0,0.12);
    flex-shrink: 0;
  }
  .color-trigger-label {
    flex: 1;
    text-align: left;
    padding: 0 10px;
    font-size: 12px;
    color: var(--gg-dark);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }
  .color-trigger-label.muted { color: var(--gg-muted); font-style: italic; font-family: inherit; }

  /* Color popover */
  .color-popover {
    position: fixed;
    background: var(--gg-white);
    border: 1px solid var(--gg-border);
    border-radius: 12px;
    padding: 14px;
    box-shadow: 0 8px 28px rgba(6,54,58,0.25);
    z-index: 200;
    width: 300px;
    max-height: 80vh;
    overflow-y: auto;
  }
  .cp-section + .cp-section { margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--gg-border); }
  .cp-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--gg-muted);
    margin: 0 0 6px 0;
  }
  .cp-swatches {
    display: flex; flex-wrap: wrap; gap: 4px;
  }
  .cp-toggle {
    display: flex; align-items: center; gap: 8px;
    font-size: 13px; font-weight: 500;
    color: var(--gg-dark); cursor: pointer;
    user-select: none;
  }
  .cp-toggle input { margin: 0; }
  .cp-actions {
    display: flex; gap: 6px; justify-content: space-between;
    margin-top: 12px;
  }
  .cp-actions button {
    padding: 7px 14px;
    border-radius: 6px;
    border: 1px solid var(--gg-border);
    background: var(--gg-white);
    font-size: 12px; font-weight: 500;
    cursor: pointer;
    color: var(--gg-dark);
  }
  .cp-actions .cp-close {
    background: var(--gg-dark);
    color: var(--gg-white);
    border-color: var(--gg-dark);
  }

  /* Collapsible swatch picker — hidden by default, opens on click */
  .swatch-disclosure { margin-top: 6px; }
  .swatch-disclosure summary.swatch-summary {
    cursor: pointer;
    font-size: 11px; font-weight: 500; color: var(--gg-muted);
    display: inline-flex; align-items: center; gap: 5px;
    padding: 5px 9px;
    border: 1px solid var(--gg-border);
    border-radius: 6px;
    list-style: none;
    user-select: none;
    transition: all .12s;
  }
  .swatch-disclosure summary.swatch-summary::-webkit-details-marker { display: none; }
  .swatch-disclosure summary.swatch-summary::marker { content: ''; }
  .swatch-disclosure summary.swatch-summary:hover {
    background: var(--gg-surface);
    border-color: var(--gg-dark);
    color: var(--gg-dark);
  }
  .swatch-disclosure[open] summary.swatch-summary {
    background: var(--gg-dark);
    color: var(--gg-white);
    border-color: var(--gg-dark);
  }
  .swatch-disclosure .swatches { margin-top: 8px; }

  .profile-pill {
    flex: 1; padding: 8px 12px;
    border: 1px solid var(--gg-border);
    background: var(--gg-white);
    border-radius: 999px;
    font-size: 12px; font-weight: 600; color: var(--gg-dark);
    cursor: pointer;
    transition: all .12s;
  }
  .profile-pill:hover { border-color: var(--gg-dark); }
  .profile-pill.active { background: var(--gg-dark); color: var(--gg-white); border-color: var(--gg-dark); }

  /* Subtab */
  .side-tabs {
    display: flex; gap: 4px; padding: 12px 12px 0 12px;
  }
  .side-tabs button {
    flex: 1; padding: 6px; border: 0; background: transparent;
    border-radius: 8px; font-size: 12px; color: var(--gg-muted);
  }
  .side-tabs button.active { background: var(--gg-dark); color: var(--gg-white); }
</style>
</head>
<body>

<div class="app">

