// than relying on the blur/commit timing, which was dropping size changes.
function persistActiveInlineEdit() {
  const el = document.querySelector('[contenteditable="true"]');
  if (!el) return;
  const host = el.closest('[data-block-id]');
  if (!host) return;
  const found = findBlock(host.dataset.blockId);
  if (!found || !found.block) return;
  const key = el.getAttribute('data-edit');
  if (!key) return;
  const path = key.split('.');
  let parent = found.block;
  for (let i = 0; i < path.length - 1; i++) { parent = parent[path[i]]; if (parent == null) return; }
  parent[path[path.length - 1]] = htmlToMarkdownText(el.innerHTML);
  save();
}

function startInlineEdit(target, td) {
  // findBlock recurses into children, so this works for blocks nested inside
  // sections (which is where most edits happen now).
  const found = findBlock(td.dataset.blockId);
  const block = found ? found.block : null;
  if (!block) return;

  const fieldKey = target.dataset.edit;
  const isMulti = target.dataset.editMulti === 'true';
  // Resolve dotted-path fields like "items.0.title" so we can edit array items.
  const path = fieldKey.split('.');
  let parent = block;
  for (let i = 0; i < path.length - 1; i++) {
    parent = parent[path[i]];
    if (parent == null) return;
  }
  const lastKey = path[path.length - 1];
  const original = parent[lastKey];

  target.contentEditable = 'true';
  target.style.outline = '2px solid #06363A';
  target.style.outlineOffset = '4px';
  target.style.borderRadius = '4px';
  target.focus();

  // Place caret at click point if possible — otherwise at end
  setTimeout(() => {
    const sel = window.getSelection();
    if (!sel.rangeCount) {
      const range = document.createRange();
      range.selectNodeContents(target);
      range.collapse(false);
      sel.removeAllRanges();
      sel.addRange(range);
    }
  }, 0);

  let committed = false;
  function commit() {
    if (committed) return;
    committed = true;
    const newText = htmlToMarkdownText(target.innerHTML);
    // Write back via the resolved path (supports both flat keys and nested
    // paths like items.0.title).
    parent[lastKey] = newText;
    save();
    hideEditToolbar();
    renderCanvas();
    renderInspector();
  }
  function onKey(ev) {
    if ((ev.metaKey || ev.ctrlKey) && (ev.key === 'b' || ev.key === 'B')) {
      ev.preventDefault();
      document.execCommand('bold');
      return;
    }
    if ((ev.metaKey || ev.ctrlKey) && (ev.key === 'i' || ev.key === 'I')) {
      ev.preventDefault();
      document.execCommand('italic');
      return;
    }
    if ((ev.metaKey || ev.ctrlKey) && (ev.key === 'k' || ev.key === 'K')) {
      ev.preventDefault();
      if (typeof window.applyInlineLink === 'function') window.applyInlineLink();
      return;
    }
    if (ev.key === 'Enter' && !ev.shiftKey && !isMulti) {
      ev.preventDefault();
      target.blur();
    }
    if (ev.key === 'Escape') {
      ev.preventDefault();
      target.innerText = String(original || '');
      committed = true;
      hideEditToolbar();
      target.contentEditable = 'false';
      target.style.outline = '';
      target.style.outlineOffset = '';
      target.removeEventListener('blur', commit);
      target.removeEventListener('keydown', onKey);
    }
  }
  target.addEventListener('blur', commit, { once: true });
  target.addEventListener('keydown', onKey);
}

function hideEditToolbar() {
  const t = document.getElementById('edit-toolbar');
  if (t) t.classList.remove('open');
}

function maybeShowEditToolbar() {
  const toolbar = document.getElementById('edit-toolbar');
  if (!toolbar) return;
  // If the user is currently interacting with the toolbar (e.g. the size
  // dropdown is open and focused), keep it visible — the selection in the
  // contenteditable has been saved and will be restored on apply.
  if (document.activeElement && document.activeElement.closest && document.activeElement.closest('.edit-toolbar')) {
    return;
  }
  const sel = window.getSelection();
  if (!sel.rangeCount || sel.isCollapsed) {
    toolbar.classList.remove('open');
    return;
  }
  // Only show inside a contenteditable element
  let node = sel.anchorNode;
  if (node && node.nodeType === 3) node = node.parentElement;
  const editable = node && node.closest && node.closest('[contenteditable="true"]');
  if (!editable) {
    toolbar.classList.remove('open');
    return;
  }
  const range = sel.getRangeAt(0);
  const rect = range.getBoundingClientRect();
  if (!rect || (rect.width === 0 && rect.height === 0)) return;
  const tw = 240;
  let left = rect.left + (rect.width / 2) - (tw / 2);
  let top = rect.top - 42;
  if (top < 8) top = rect.bottom + 8;
  if (left < 8) left = 8;
  if (left + tw > window.innerWidth - 8) left = window.innerWidth - tw - 8;
  toolbar.style.left = left + 'px';
  toolbar.style.top = top + 'px';
  toolbar.classList.add('open');

  // Sync the custom size picker label + active option to the selection's size
  const sizeBtn = document.getElementById('edit-size-btn');
  const sizeMenu = document.getElementById('edit-size-menu');
  if (sizeBtn && sizeMenu) {
    let n = sel.anchorNode;
    if (n && n.nodeType === 3) n = n.parentElement;
    let detected = '';
    while (n && n.style && n.tagName !== 'BODY') {
      if (n.style.fontSize) {
        const m = String(n.style.fontSize).match(/(\d+)/);
        if (m) { detected = m[1]; break; }
      }
      n = n.parentElement;
    }
    if (!detected) {
      let probe = sel.anchorNode;
      if (probe && probe.nodeType === 3) probe = probe.parentElement;
      if (probe) {
        const cs = window.getComputedStyle(probe);
        const px = parseInt(cs.fontSize, 10);
        if (px) detected = String(px);
      }
    }
    sizeBtn.firstChild.textContent = (detected || 'Size') + ' ';
    sizeMenu.querySelectorAll('button[data-size]').forEach(o => {
      o.classList.toggle('active', o.dataset.size === detected);
    });
  }
}

/* --------- Block ops --------- */
let _lastAddAt = 0;
function addBlock(type, idx, parentId) {
  const now = Date.now();
  if (now - _lastAddAt < 200) return;
  _lastAddAt = now;
  const b = mkBlock(type);
  let target;
  if (parentId) {
    const f = findBlock(parentId);
    if (!f) return;
    f.block.children = f.block.children || [];
    target = f.block.children;
  } else {
    target = State.blocks;
  }
  if (idx == null) target.push(b);
  else target.splice(idx, 0, b);
  State.selectedId = b.id;
  save(); renderCanvas(); renderInspector();
  // Entrance animation for the freshly added block.
  requestAnimationFrame(() => {
    const td = document.querySelector(`td[data-block-id="${b.id}"]`);
    if (td) {
      td.classList.add('gg-just-added');
      setTimeout(() => td.classList.remove('gg-just-added'), 280);
      td.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  });
  toast(`${BlockTypes[type].label} added`);
}

function addBlockNearSelection(type) {
  if (State.selectedId) {
    const f = findBlock(State.selectedId);
    if (f) {
      addBlock(type, f.index + 1, f.parent ? f.parent.id : null);
      return;
    }
  }
  addBlock(type);
}

function selectBlock(id) {
  State.selectedId = id;
  // Update selection visually WITHOUT re-rendering the canvas (preserves any
  // contenteditable elements and avoids killing the click target before
  // bubbling completes).
  document.querySelectorAll('.canvas-block').forEach(el => {
    el.classList.toggle('selected', el.dataset.blockId === id);
  });
  renderInspector();
}

function moveBlockToTarget(blockId, target) {
  const f = findBlock(blockId);
  if (!f) return;
  if (!target) target = { parentId: null, index: null };
  // Don't allow dropping a section into itself
  if (target.parentId === blockId) return;
  // Remove from current location
  const [block] = f.siblings.splice(f.index, 1);
  // Determine destination
  let dest;
  if (target.parentId) {
    const fp = findBlock(target.parentId);
    if (!fp) { f.siblings.splice(f.index, 0, block); return; }
    fp.block.children = fp.block.children || [];
    dest = fp.block.children;
  } else {
    dest = State.blocks;
  }
  let idx = target.index != null ? target.index : dest.length;
  // If same parent and target was after source, adjust
  if (dest === f.siblings && target.index != null && target.index > f.index) idx--;
  dest.splice(idx, 0, block);
  save(); renderCanvas(); renderInspector();
  toast('Block moved');
}

function moveBlock(id, dir) {
  const f = findBlock(id);
  if (!f) return;
  const j = f.index + dir;
  if (j < 0 || j >= f.siblings.length) return;
  [f.siblings[f.index], f.siblings[j]] = [f.siblings[j], f.siblings[f.index]];
  save(); renderCanvas();
}
function deleteBlock(id) {
  const f = findBlock(id);
  if (!f) return;
  f.siblings.splice(f.index, 1);
  if (State.selectedId === id) State.selectedId = null;
  save(); renderCanvas(); renderInspector();
}
function duplicateBlock(id) {
  const f = findBlock(id);
  if (!f) return;
  const copy = JSON.parse(JSON.stringify(f.block));
  // Re-id this and any descendants
  function reID(b) { b.id = uid(); if (b.children) b.children.forEach(reID); }
  reID(copy);
  f.siblings.splice(f.index + 1, 0, copy);
  save(); renderCanvas();
}
function copyBlockHTML(id) {
  const f = findBlock(id);
  if (!f) return;
  const html = renderBlockForExport(f.block);
  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(html).then(
      () => toast('HTML copied'),
      () => fallbackCopy(html)
    );
  } else {
    fallbackCopy(html);
  }
  function fallbackCopy(text) {
    const ta = document.createElement('textarea');
    ta.value = text;
    ta.style.position = 'fixed';
    ta.style.opacity = '0';
    document.body.appendChild(ta);
    ta.select();
    try { document.execCommand('copy'); toast('HTML copied'); }
    catch { toast('Copy failed'); }
    document.body.removeChild(ta);
  }
}

/* --------- Export round-trip metadata --------- */
// Each exported block is preceded by a comment with base64-encoded JSON of the
// block's data. Re-importing the HTML reconstructs the exact same blocks.
function encodeBlockMeta(block) {
  try {
    const json = JSON.stringify(block);
    const b64 = btoa(unescape(encodeURIComponent(json)));
    return `<!--gg-block:${b64}-->`;
  } catch { return ''; }
}
function decodeBlockMeta(b64) {
  try {
    return JSON.parse(decodeURIComponent(escape(atob(b64))));
  } catch { return null; }
}

/* --------- Export --------- */
function applyUtmDeep(b) {
  if (b.url) b.url = applyUtm(b.url);
  if (b.btnUrl) b.btnUrl = applyUtm(b.btnUrl);
  if (b.link) b.link = applyUtm(b.link);
  if (b.children) b.children.forEach(applyUtmDeep);
}
function stripCanvasAttrs(html) {
  return html
    // Empty-image placeholders are builder-only — strip them so the sent email
    // does not ship a "+ Click to add image" prompt.
    .replace(/<div[^>]*class="[^"]*gg-img-placeholder[^"]*"[^>]*>[\s\S]*?<\/div>/g, '')
    .replace(/\s*data-block-id="[^"]+"/g, '')
    .replace(/\s*data-edit(?:-multi)?="[^"]*"/g, '')
    .replace(/\s*data-img-edit="[^"]*"/g, '')
    .replace(/\s*data-gg-link="[^"]*"/g, '');
}
function renderBlockForExport(block) {
  const clone = JSON.parse(JSON.stringify(block));
  applyUtmDeep(clone);
  const meta = encodeBlockMeta(block);
  const html = `${meta}<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-collapse:separate;font-family:${State.brand.font};">${BlockTypes[clone.type].render(clone)}</table>`;
  return stripCanvasAttrs(html);
}

/* --------- Snapshot heroes as PNGs (dark-mode safe export) --------- */
let _html2canvasLoading = null;
function loadHtml2canvas() {
  if (window.html2canvas) return Promise.resolve(window.html2canvas);
  if (_html2canvasLoading) return _html2canvasLoading;
  _html2canvasLoading = new Promise((resolve, reject) => {
    const s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js';
    s.onload = () => resolve(window.html2canvas);
    s.onerror = () => reject(new Error('html2canvas failed to load'));
    document.head.appendChild(s);
  });
  return _html2canvasLoading;
}

async function snapshotBlockToBlob(blockId) {
  const html2c = await loadHtml2canvas();
  const td = document.querySelector(`td[data-block-id="${blockId}"]`);
  if (!td) throw new Error('Block not found on canvas');
  const overlay = td.querySelector('.block-actions');
  const wasSelected = td.classList.contains('selected');
  if (overlay) overlay.style.display = 'none';
  td.classList.remove('selected');
  td.style.outline = 'none';
  try {
    const canvas = await html2c(td, {
      backgroundColor: null,
      scale: 1.5,
      useCORS: true,
      allowTaint: true,
      logging: false
    });
    const blob = await new Promise(r => canvas.toBlob(r, 'image/png'));
    if (!blob) throw new Error('Canvas produced no image');
    return blob;
  } finally {
    if (overlay) overlay.style.display = '';
    if (wasSelected) td.classList.add('selected');
    td.style.outline = '';
  }
}

async function convertHeroToImageBlock(block) {
  toast('Capturing hero…');
  let blob;
  try {
    blob = await snapshotBlockToBlob(block.id);
  } catch (err) {
    alert('Could not capture hero:\n\n' + err.message);
    return;
  }

  // Download the PNG so the user can upload it manually
  const objectUrl = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = objectUrl;
  a.download = `hero-${block.id}.png`;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  setTimeout(() => URL.revokeObjectURL(objectUrl), 1000);

  toast('PNG downloaded — upload it to HubSpot Files');

  const hosted = prompt(
    'Hero PNG downloaded to your computer.\n\nNext steps:\n' +
    '1. Open HubSpot → Marketing → Files & Templates → Files\n' +
    '2. Upload the PNG\n' +
    '3. Click the uploaded file and copy its URL\n' +
    '4. Paste the URL below:'
  );
  if (!hosted || !hosted.trim()) {
    toast('Conversion cancelled — hero left as is');
    return;
  }
  replaceWithImageBlock(block, hosted.trim());
  toast('Hero converted to image ✓');
}

