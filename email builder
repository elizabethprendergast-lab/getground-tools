function updateSwatchActive(swContainer, color) {
  if (!swContainer) return;
  const c = (color || '').toLowerCase();
  swContainer.querySelectorAll('.swatch').forEach(s => {
    s.classList.toggle('active', (s.dataset.color || '').toLowerCase() === c);
  });
}

function showColorPopover(anchor, block, field) {
  // Close any existing popover
  document.querySelectorAll('.color-popover').forEach(p => p.remove());

  const popover = document.createElement('div');
  popover.className = 'color-popover';
  const all = Object.values(getActivePalette()).flat();
  const cur = (block[field.key] || '').toLowerCase();
  const hasGradient = !!field.gradient;
  const gradOn = !!(block.gradFrom && block.gradTo);

  popover.innerHTML = `
    <div class="cp-section">
      <p class="cp-label">Brand swatches</p>
      <div class="cp-swatches" data-cp-main>
        ${all.map(c => `<button class="swatch ${c.toLowerCase()===cur?'active':''}" data-color="${c}" style="background:${c}"></button>`).join('')}
      </div>
      <p class="cp-label" style="margin-top:10px">Custom</p>
      <div class="field-color">
        <input type="color" class="cp-native" value="${block[field.key]||'#000000'}">
        <input type="text" class="cp-hex" value="${block[field.key]||''}" placeholder="#hex" style="font-family:ui-monospace,Menlo,monospace;font-size:12px">
      </div>
    </div>
    ${hasGradient ? `
    <div class="cp-section">
      <label class="cp-toggle"><input type="checkbox" class="cp-grad-on" ${gradOn?'checked':''}> Use gradient</label>
      <div class="cp-grad-controls" style="display:${gradOn?'block':'none'};margin-top:10px">
        <p class="cp-label">Top colour</p>
        <div class="cp-swatches" data-cp-from>
          ${all.map(c => `<button class="swatch ${c.toLowerCase()===(block.gradFrom||'').toLowerCase()?'active':''}" data-color="${c}" style="background:${c}"></button>`).join('')}
        </div>
        <p class="cp-label" style="margin-top:10px">Bottom colour</p>
        <div class="cp-swatches" data-cp-to>
          ${all.map(c => `<button class="swatch ${c.toLowerCase()===(block.gradTo||'').toLowerCase()?'active':''}" data-color="${c}" style="background:${c}"></button>`).join('')}
        </div>
        <p class="cp-label" style="margin-top:10px">Stop <span style="float:right;color:var(--gg-muted);font-weight:400" id="cp-stop-val">${block.gradStop||100}%</span></p>
        <input type="range" class="cp-grad-stop" min="0" max="100" step="5" value="${block.gradStop||100}" style="width:100%">
      </div>
    </div>` : ''}
    <div class="cp-actions">
      <button class="cp-clear" type="button">Clear</button>
      <button class="cp-close" type="button">Done</button>
    </div>`;

  document.body.appendChild(popover);

  // Position
  const rect = anchor.getBoundingClientRect();
  let left = rect.left;
  let top = rect.bottom + 6;
  if (left + 320 > window.innerWidth) left = window.innerWidth - 320;
  if (top + popover.offsetHeight > window.innerHeight) top = rect.top - popover.offsetHeight - 6;
  if (top < 8) top = 8;
  popover.style.left = left + 'px';
  popover.style.top = top + 'px';

  function refreshAnchor() {
    const v = block[field.key];
    const swatch = anchor.querySelector('.color-trigger-swatch');
    const label = anchor.querySelector('.color-trigger-label');
    if (v) {
      swatch.style.background = v;
      label.textContent = v;
      label.classList.remove('muted');
    } else {
      swatch.style.background = 'repeating-linear-gradient(45deg, #f4f4f4, #f4f4f4 4px, #fff 4px, #fff 8px)';
      label.textContent = 'Default / unset';
      label.classList.add('muted');
    }
  }

  function setMain(c) {
    block[field.key] = c;
    save(); renderCanvas();
    refreshAnchor();
    popover.querySelectorAll('[data-cp-main] .swatch').forEach(s =>
      s.classList.toggle('active', (s.dataset.color || '').toLowerCase() === (c || '').toLowerCase()));
    popover.querySelector('.cp-native').value = c || '#000000';
    popover.querySelector('.cp-hex').value = c || '';
  }

  popover.querySelectorAll('[data-cp-main] .swatch').forEach(s => {
    s.addEventListener('click', e => { e.stopPropagation(); setMain(s.dataset.color); });
  });
  popover.querySelector('.cp-native').addEventListener('input', e => setMain(e.target.value));
  popover.querySelector('.cp-hex').addEventListener('change', e => setMain(e.target.value.trim()));

  if (hasGradient) {
    const gradOnCb = popover.querySelector('.cp-grad-on');
    const gradControls = popover.querySelector('.cp-grad-controls');
    gradOnCb.addEventListener('change', e => {
      gradControls.style.display = e.target.checked ? 'block' : 'none';
      if (!e.target.checked) {
        block.gradFrom = ''; block.gradTo = '';
        save(); renderCanvas();
      } else if (!block.gradFrom || !block.gradTo) {
        // Seed with sensible defaults if turning gradient on with empty values
        block.gradFrom = block.gradFrom || (block[field.key] || all[0]);
        block.gradTo = block.gradTo || all[Math.floor(all.length / 2)];
        block.gradStop = block.gradStop || 100;
        save(); renderCanvas();
      }
    });
    popover.querySelectorAll('[data-cp-from] .swatch').forEach(s => {
      s.addEventListener('click', e => {
        e.stopPropagation();
        block.gradFrom = s.dataset.color;
        popover.querySelectorAll('[data-cp-from] .swatch').forEach(x => x.classList.toggle('active', x === s));
        save(); renderCanvas();
      });
    });
    popover.querySelectorAll('[data-cp-to] .swatch').forEach(s => {
      s.addEventListener('click', e => {
        e.stopPropagation();
        block.gradTo = s.dataset.color;
        popover.querySelectorAll('[data-cp-to] .swatch').forEach(x => x.classList.toggle('active', x === s));
        save(); renderCanvas();
      });
    });
    popover.querySelector('.cp-grad-stop').addEventListener('input', e => {
      block.gradStop = Number(e.target.value);
      const sv = popover.querySelector('#cp-stop-val');
      if (sv) sv.textContent = block.gradStop + '%';
      save(); renderCanvas();
    });
  }

  popover.querySelector('.cp-clear').addEventListener('click', () => {
    setMain('');
    if (hasGradient) {
      block.gradFrom = ''; block.gradTo = '';
      save(); renderCanvas();
    }
    popover.remove();
    document.removeEventListener('mousedown', closeOnOutside, true);
  });
  popover.querySelector('.cp-close').addEventListener('click', () => {
    popover.remove();
    document.removeEventListener('mousedown', closeOnOutside, true);
  });

  function closeOnOutside(e) {
    if (popover.contains(e.target) || anchor.contains(e.target)) return;
    popover.remove();
    document.removeEventListener('mousedown', closeOnOutside, true);
  }
  setTimeout(() => document.addEventListener('mousedown', closeOnOutside, true), 50);
}

