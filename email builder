    <label style="display:flex;align-items:center;gap:8px;font-size:13px;margin-top:8px;color:var(--gg-muted)">
      Or load a draft file: <input type="file" id="imp-file" accept=".html,.htm,.txt" style="font-size:12px">
    </label>
    <div class="modal-actions">
      <button class="icon-btn" id="modal-close">Cancel</button>
      <button class="icon-btn" id="imp-raw" style="border:1px solid var(--gg-border)">Keep as raw HTML</button>
      <button class="icon-btn primary" id="imp-do">Parse into blocks</button>
    </div>`;
  document.getElementById('modal-bg').classList.add('open');

  document.getElementById('imp-do').onclick = () => {
    const html = document.getElementById('imp-area').value.trim();
    if (!html) { toast('Paste some HTML first'); return; }
    let parsed;
    try {
      parsed = parseImportedHTML(html);
    } catch (e) {
      console.error('parseImportedHTML threw:', e);
      toast('Parse error: ' + (e && e.message ? e.message : 'unknown'));
      return;
    }
    if (!parsed || !parsed.length) { toast('Could not find editable content'); return; }
    if (document.getElementById('imp-replace').checked) State.blocks = parsed;
    else State.blocks = State.blocks.concat(parsed);
    State.selectedId = null;
    save(); renderCanvas(); renderInspector();
    closeModal(); toast(`Imported ${parsed.length} editable blocks`);
  };

  document.getElementById('imp-raw').onclick = () => {
    const html = document.getElementById('imp-area').value.trim();
    if (!html) return;
    ensureRawHtmlType();
    const block = mkBlock('rawhtml', { html });
    if (document.getElementById('imp-replace').checked) State.blocks = [block];
    else State.blocks.push(block);
    save(); renderCanvas();
    closeModal(); toast('Imported as raw HTML');
  };

  const impFile = document.getElementById('imp-file');
  if (impFile) impFile.onchange = (ev) => {
    const file = ev.target.files && ev.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = () => {
      document.getElementById('imp-area').value = reader.result;
      toast('Draft loaded — now click "Parse into blocks"');
    };
    reader.readAsText(file);
  };

  document.getElementById('modal-close').onclick = () => closeModal();
}

function ensureRawHtmlType() {
  if (BlockTypes.rawhtml) return;
  BlockTypes.rawhtml = {
    label: 'Raw HTML',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 18l6-6-6-6M8 6l-6 6 6 6"/></svg>',
    defaults: () => ({ html: '<p style="font-family:Arial,sans-serif;padding:24px;">Paste raw HTML here</p>' }),
    render: (b) => `<tr><td style="padding:0;background:#FFFFFF;">${b.html || ''}</td></tr>`,
    fields: [
      { key: 'html', label: 'Raw HTML (edit source directly)', type: 'textarea' }
    ]
  };
}

function parseImportedHTML(html) {
  // First try the round-trip metadata: any HTML that was originally exported
  // from this builder includes <!--gg-block:BASE64--> comments with the raw block data.
  const metaBlocks = [];
  const metaRe = /<!--gg-block:([A-Za-z0-9+/=]+)-->/g;
  let m;
  while ((m = metaRe.exec(html)) !== null) {
    const decoded = decodeBlockMeta(m[1]);
    if (decoded && decoded.type && BlockTypes[decoded.type]) {
      // Ensure a fresh ID so re-imports don't clash with anything currently on canvas
      decoded.id = uid();
      // Also fresh IDs for any nested children
      if (decoded.children) {
        function reID(b) { b.id = uid(); if (b.children) b.children.forEach(reID); }
        decoded.children.forEach(reID);
      }
      metaBlocks.push(decoded);
    }
  }
  if (metaBlocks.length) return metaBlocks;

  // No metadata found — try parsing top-level tables (each table = one block)
  const doc = new DOMParser().parseFromString(html, 'text/html');
  const blocks = [];

  function getStyleProp(style, prop) {
    if (!style) return '';
    const re = new RegExp(prop.replace(/[A-Z]/g, c => '-' + c.toLowerCase()) + '\\s*:\\s*([^;]+)', 'i');
    const m = style.match(re);
    return m ? m[1].trim() : '';
  }

  function findGradient(...styles) {
    for (const s of styles) {
      if (!s) continue;
      const m = s.match(/linear-gradient\([^)]*?(#[0-9a-fA-F]{3,8}|rgba?\([^)]+\))[^,)]*,\s*(#[0-9a-fA-F]{3,8}|rgba?\([^)]+\))/i);
      if (m) return { from: m[1], to: m[2] };
    }
    return null;
  }
  function findBg(...styles) {
    for (const s of styles) {
      if (!s) continue;
      const m = s.match(/(?:^|;|\s)background(?:-color)?\s*:\s*(#[0-9a-fA-F]{3,8}|rgba?\([^)]+\))/i);
      if (m && !/^#fff(fff)?$/i.test(m[1]) && !/255,\s*255,\s*255/.test(m[1])) return m[1];
    }
    return '';
  }

  function identifyTableBlock(table) {
    const tableStyle = table.getAttribute('style') || '';
    const firstTd = table.querySelector(':scope > tbody > tr > td, :scope > tr > td');
    const tdStyle = firstTd ? (firstTd.getAttribute('style') || '') : '';

    const grad = findGradient(tableStyle, tdStyle);
    const bg = findBg(tableStyle, tdStyle);

    // Action card list pattern: outer table with multiple rows, each row contains
    // an <a> wrapping a styled card table. Detect badge / heading / body / cta
    // and emit one `actioncard` block per row.
    const directRows = Array.from(table.querySelectorAll(':scope > tbody > tr, :scope > tr'));
    if (directRows.length >= 2 && !grad && !bg) {
      const cards = directRows.map(tr => {
        const anchor = tr.querySelector('a[href]');
        const innerTable = tr.querySelector('table');
        if (!innerTable) return null;
        const innerStyle = innerTable.getAttribute('style') || '';
        const innerTdStyle = (innerTable.querySelector('td') || {}).getAttribute ? innerTable.querySelector('td').getAttribute('style') || '' : '';
        const cBg = findBg(innerStyle, innerTdStyle);
        const cGrad = findGradient(innerStyle, innerTdStyle);
        const cBorder = (() => {
          const m = (innerStyle + ';' + innerTdStyle).match(/border\s*:\s*[^;]*?(#[0-9a-fA-F]{3,8}|rgba?\([^)]+\))/i);
          return m ? m[1] : '';
        })();
        if (!cBg && !cGrad && !cBorder) return null;

        // Probe for action-card structure: a badge span, a heading, a paragraph, a cta span
        const spans = Array.from(innerTable.querySelectorAll('span'));
        const badgeSpan = spans.find(s => {
          const st = s.getAttribute('style') || '';
          const txt = (s.textContent || '').trim();
          return /background[-\s]*color/i.test(st) && /border-radius/i.test(st) && txt && txt.length <= 6;
        });
        const ctaSpan = spans.find(s => {
          const st = s.getAttribute('style') || '';
          return /border-bottom/i.test(st) || /text-decoration\s*:\s*underline/i.test(st);
        });
        const headingEl = innerTable.querySelector('h1, h2, h3, h4, div[style*="font-weight"]');
        const bodyEl = innerTable.querySelector('p');

        if (badgeSpan && headingEl && bodyEl) {
          // Action card pattern matched
          const badgeBg = (() => {
            const m = (badgeSpan.getAttribute('style') || '').match(/background(?:-color)?\s*:\s*(#[0-9a-fA-F]{3,8}|rgba?\([^)]+\))/i);
            return m ? m[1] : '#A3ECEE';
          })();
          const accent = ctaSpan ? (() => {
            const st = ctaSpan.getAttribute('style') || '';
            const m = st.match(/border-bottom\s*:\s*[^;]*?(#[0-9a-fA-F]{3,8}|rgba?\([^)]+\))/i);
            return m ? m[1] : '#A3ECEE';
          })() : '#A3ECEE';
          const hc = (() => {
            const m = (headingEl.getAttribute('style') || '').match(/color\s*:\s*(#[0-9a-fA-F]{3,8}|rgba?\([^)]+\))/i);
            return m ? m[1] : '#06363A';
          })();
          const bc = (() => {
            const m = (bodyEl.getAttribute('style') || '').match(/color\s*:\s*(#[0-9a-fA-F]{3,8}|rgba?\([^)]+\))/i);
            return m ? m[1] : '#5A6A66';
          })();
          return {
            kind: 'actioncard',
            data: {
              number: (badgeSpan.textContent || '').trim(),
              heading: htmlToMarkdownText(headingEl.innerHTML).trim(),
              body: htmlToMarkdownText(bodyEl.innerHTML).trim(),
              ctaText: ctaSpan ? (ctaSpan.textContent || '').trim() : '',
              url: anchor ? (anchor.getAttribute('href') || '#') : '#',
              bg: cBg || '#FBFBF8',
              border: cBorder || '#E6E4DC',
              badgeBg, accent,
              headingColor: hc,
              bodyColor: bc,
              radius: 24,
              paddingY: 24
            }
          };
        }

        // Fall back to generic styled-text card
        const parts = [];
        Array.from(innerTable.querySelectorAll('h1, h2, h3, h4, div, p, span')).forEach(el => {
          if (el.closest('p, h1, h2, h3, h4') && el.closest('p, h1, h2, h3, h4') !== el) return;
          const t = htmlToMarkdownText(el.innerHTML).trim();
          if (t && !parts.includes(t)) parts.push(t);
        });
        if (!parts.length) return null;
        return { kind: 'text', data: { bg: cBg, grad: cGrad, text: parts.join('\n\n'), radius: 24, radiusPos: 'all', paddingY: 24 } };
      });
      if (cards.every(c => c !== null) && cards.length >= 2) {
        return cards.map(c => {
          if (c.kind === 'actioncard') return mkBlock('actioncard', c.data);
          const d = { text: c.data.text, radius: c.data.radius, radiusPos: 'all', paddingY: 24 };
          if (c.data.grad) { d.gradFrom = c.data.grad.from; d.gradTo = c.data.grad.to; d.gradStop = 100; d.bg = c.data.grad.to; }
          else d.bg = c.data.bg;
          return mkBlock('text', d);
        });
      }
    }

    // Image-only block (img wrapped in anchor or alone)
    const img = table.querySelector('img');
    const otherText = table.querySelector('h1, h2, h3, h4, p');
    const onlyImage = img && !otherText;
    if (onlyImage) {
      const a = img.closest('a');
      return mkBlock('image', {
        src: img.getAttribute('src') || '',
        alt: img.getAttribute('alt') || '',
        link: a ? (a.getAttribute('href') || '') : '',
        align: 'center'
      });
    }

    // Hero (h1 inside, often with gradient/bg)
    const h1 = table.querySelector('h1');
    if (h1) {
      const eyebrow = (() => {
        // optional eyebrow paragraph above h1 with uppercase short text
        const prev = h1.previousElementSibling;
        if (prev && prev.tagName === 'P') {
          const txt = prev.textContent.trim();
          if (txt.length < 60 && txt === txt.toUpperCase()) return txt;
        }
        return '';
      })();
      const subP = h1.nextElementSibling;
      const sub = (subP && subP.tagName === 'P') ? htmlToMarkdownText(subP.innerHTML).trim() : '';
      const btn = table.querySelector('a[style*="padding"]');
      const data = {
        heading: htmlToMarkdownText(h1.innerHTML).trim(),
        eyebrow, sub,
        btnText: btn ? btn.textContent.trim() : '',
        btnUrl: btn ? (btn.getAttribute('href') || '') : '',
        bg: grad ? grad.to : (bg || '#A3ECEE')
      };
      if (grad) { data.gradFrom = grad.from; data.gradTo = grad.to; data.gradStop = 100; }
      return mkBlock('hero', data);
    }

    // Standalone heading (h2/h3/h4 with no body paragraphs)
    const heading = table.querySelector('h2, h3, h4');
    if (heading && !table.querySelector('p')) {
      const sizes = { H2: 22, H3: 18, H4: 18 };
      const data = {
        text: htmlToMarkdownText(heading.innerHTML).trim(),
        size: sizes[heading.tagName] || 22
      };
      if (grad) { data.gradFrom = grad.from; data.gradTo = grad.to; data.gradStop = 100; data.bg = grad.to; }
      else if (bg) data.bg = bg;
      return mkBlock('heading', data);
    }

    // Checklist: rows of two cells, first cell is a tick/bullet character
    const rows = Array.from(table.querySelectorAll(':scope > tbody > tr, :scope > tr, :scope > tbody > tr > td > table > tbody > tr, :scope > tr > td > table > tbody > tr, :scope > tr > td > table > tr'));
    const innerTables = Array.from(table.querySelectorAll('table'));
    let checklistRows = null;
    for (const t of [table, ...innerTables]) {
      const trs = Array.from(t.querySelectorAll(':scope > tbody > tr, :scope > tr'));
      if (trs.length < 2) continue;
      const items = [];
      const ok = trs.every(tr => {
        const cells = Array.from(tr.children).filter(c => c.tagName === 'TD');
        if (cells.length !== 2) return false;
        const first = cells[0].textContent.trim();
        if (!/^[✓✔☑•·\-\*]+$/u.test(first)) return false;
        const item = cells[1].textContent.trim();
        if (!item) return false;
        items.push(item);
        return true;
      });
      if (ok && items.length >= 2) { checklistRows = items; break; }
    }
    if (checklistRows) {
      return mkBlock('checklist', { items: checklistRows });
    }

    // Card pattern: nested table with bg/gradient containing paragraphs
    const nested = table.querySelector('table');
    if (nested && nested !== table) {
      const ns = nested.getAttribute('style') || '';
      const nGrad = findGradient(ns);
      const nBg = findBg(ns);
      if (nGrad || nBg) {
        const paras = Array.from(nested.querySelectorAll('p')).map(p => htmlToMarkdownText(p.innerHTML).trim()).filter(Boolean);
        if (paras.length) {
          const data = {
            text: paras.join('\n\n'),
            radius: 12, radiusPos: 'all'
          };
          if (nGrad) { data.gradFrom = nGrad.from; data.gradTo = nGrad.to; data.gradStop = 100; data.bg = nGrad.to; }
          else data.bg = nBg;
          return mkBlock('text', data);
        }
      }
    }

    // Standalone button (no h1/h2 before it)
    const a = table.querySelector('a');
    if (a) {
      const aStyle = a.getAttribute('style') || '';
      const isButton = /background[-\s]*color/i.test(aStyle) || (/padding/i.test(aStyle) && /border-radius/i.test(aStyle));
      if (isButton && !table.querySelector('h1, h2, h3, h4, p')) {
        const bgB = getStyleProp(aStyle, 'background-color') || getStyleProp(aStyle, 'background') || '#06363A';
        const colB = getStyleProp(aStyle, 'color') || '#FFFFFF';
        return mkBlock('button', {
          text: a.textContent.trim() || 'Click here',
          url: a.getAttribute('href') || '#',
          bg: bgB, color: colB, align: 'left'
        });
      }
    }

    // Default: text block with whatever paragraphs are here (preserves markdown bold/italic)
    const paragraphs = Array.from(table.querySelectorAll('p'))
      .map(p => htmlToMarkdownText(p.innerHTML).trim())
      .filter(Boolean);
    if (paragraphs.length) {
      const data = { text: paragraphs.join('\n\n') };
      if (grad) { data.gradFrom = grad.from; data.gradTo = grad.to; data.gradStop = 100; data.bg = grad.to; data.radius = 12; data.radiusPos = 'all'; }
      else if (bg) data.bg = bg;
      return mkBlock('text', data);
    }

    return null;
  }

  // Find sections — chunks of the email that should each become a block.
  // For emails built in this builder: each <tr> in the outer container = one section.
  // For emails from external tools (HubSpot etc): often each <div class="hse-column-container">
  // or each top-level <div> is a section. Hybrid strategy:
  //   1. If we find <div class="hse-column-container"> wrappers (HubSpot pattern), use those.
  //   2. Otherwise, use top-level tables.
  // For each section we try identifyTableBlock; if it returns null, we fall back to
  // a raw HTML block preserving the original markup so it still renders correctly.
  ensureRawHtmlType();

  const hseSections = Array.from(doc.querySelectorAll('.hse-column-container'));
  const sectionsList = [];

  if (hseSections.length >= 2) {
    // HubSpot-style email - each column container is a section
    hseSections.forEach(div => {
      const innerTable = div.querySelector('table');
      sectionsList.push({ container: div, table: innerTable });
    });
  } else {
    // Default: top-level tables
    const topTables = Array.from(doc.querySelectorAll('table')).filter(t => {
      let p = t.parentElement;
      while (p && p.tagName !== 'BODY' && p !== doc.body) {
        if (p.tagName === 'TABLE') return false;
        p = p.parentElement;
      }
      return true;
    });
    topTables.forEach(t => sectionsList.push({ container: t, table: t }));
  }

  // If we detected hseSections, preserve everything as raw HTML to keep visual fidelity.
  // External email layouts (HubSpot, Mailchimp, etc.) have too much custom styling
  // for our block model to reconstruct losslessly.
  const isHseMode = hseSections.length >= 2;

  if (sectionsList.length) {
    sectionsList.forEach(({ container, table }) => {
      try {
        if (isHseMode) {
          // External email - keep each section as raw HTML
          blocks.push(mkBlock('rawhtml', { html: container.outerHTML }));
        } else {
          // Top-level table - try parsing first, fall back to rawhtml
          let blk = null;
          if (table) blk = identifyTableBlock(table);
          if (Array.isArray(blk) && blk.length) {
            blocks.push(...blk);
          } else if (blk) {
            blocks.push(blk);
          } else {
            blocks.push(mkBlock('rawhtml', { html: container.outerHTML }));
          }
        }
      } catch (e) {
        console.error('identifyTableBlock failed for section', container, e);
        try {
          blocks.push(mkBlock('rawhtml', { html: container.outerHTML }));
        } catch (e2) { /* skip */ }
      }
    });
    if (blocks.length) return blocks;
  }

  // Last-resort fallback: walk individual elements
  const all = Array.from(doc.querySelectorAll('h1, h2, h3, h4, p, a, img'));
  if (!all.length) return [];

  function elInnerToMarkdown(el) {
    return htmlToMarkdownText(el.innerHTML).trim();
  }
  function findGradientAncestor(el) {
    let cur = el.parentElement;
    while (cur && cur.tagName !== 'BODY') {
      const style = (cur.getAttribute && cur.getAttribute('style')) || '';
      if (/linear-gradient\(/i.test(style)) {
        const m = style.match(/linear-gradient\([^)]*?(#[0-9a-fA-F]{3,8}|rgba?\([^)]+\))[^,)]*,\s*(#[0-9a-fA-F]{3,8}|rgba?\([^)]+\))/);
        if (m) return { from: m[1], to: m[2] };
      }
      cur = cur.parentElement;
    }
    return null;
  }
  function findSolidBgAncestor(el) {
    let cur = el.parentElement;
    while (cur && cur.tagName !== 'BODY') {
      const bg = cur.style && (cur.style.background || cur.style.backgroundColor);
      if (bg && /^#?[0-9a-fA-F]{3,8}$|rgba?\(/.test(bg) && !/^#fff(fff)?$/i.test(bg) && !/255,\s*255,\s*255/.test(bg)) {
        return bg;
      }
      cur = cur.parentElement;
    }
    return '';
  }

  // Skip nested duplicates: if an ancestor of this element is also in the list, skip
  function hasInterestingAncestor(el) {
    let p = el.parentElement;
    while (p && p !== doc.body) {
      if (all.includes(p)) return true;
      p = p.parentElement;
    }
    return false;
  }

  let textBuffer = [];
  function flushText() {
    if (textBuffer.length) {
      blocks.push(mkBlock('text', { text: textBuffer.join('\n\n'), align: 'left' }));
      textBuffer = [];
    }
  }

  function readStyle(el, prop) {
    const style = el.getAttribute('style') || '';
    const re = new RegExp(prop.replace(/-/g,'\\-') + '\\s*:\\s*([^;]+)', 'i');
    const m = style.match(re);
    return m ? m[1].trim() : '';
  }

  all.forEach(el => {
    if (hasInterestingAncestor(el)) return;

    const tag = el.tagName.toLowerCase();
    const text = el.textContent.trim();
    const style = el.getAttribute('style') || '';

    // Anchor: detect button vs inline link
    if (tag === 'a') {
      const isButton = /background[-\s]*color/i.test(style) || /padding/i.test(style) || /border-radius/i.test(style);
      if (isButton) {
        flushText();
        blocks.push(mkBlock('button', {
          text: text || 'Click here',
          url: el.getAttribute('href') || '#',
          bg: readStyle(el, 'background-color') || readStyle(el, 'background') || '#06363A',
          color: readStyle(el, 'color') || '#FFFFFF',
          align: 'left'
        }));
      }
      return;
    }

    if (tag === 'img') {
      flushText();
      blocks.push(mkBlock('image', {
        src: el.getAttribute('src') || '',
        alt: el.getAttribute('alt') || '',
        link: '',
        align: 'center'
      }));
      return;
    }

    if (tag === 'h1' || tag === 'h2' || tag === 'h3' || tag === 'h4') {
      if (!text) return;
      flushText();
      const sizeMap = { h1: 32, h2: 22, h3: 18, h4: 18 };
      const mdText = elInnerToMarkdown(el);
      // If the heading sits inside a gradient table, treat it as a Hero
      const grad = findGradientAncestor(el);
      const solidBg = findSolidBgAncestor(el);
      if (tag === 'h1' && (grad || solidBg)) {
        const heroData = { heading: mdText, eyebrow: '', sub: '', btnText: '' };
        if (grad) { heroData.gradFrom = grad.from; heroData.gradTo = grad.to; heroData.gradStop = 100; heroData.bg = grad.to; }
        else { heroData.bg = solidBg; heroData.gradFrom = ''; heroData.gradTo = ''; }
        blocks.push(mkBlock('hero', heroData));
        return;
      }
      const headingData = { text: mdText, size: sizeMap[tag] };
      if (grad) { headingData.gradFrom = grad.from; headingData.gradTo = grad.to; headingData.gradStop = 100; headingData.bg = grad.to; }
      else if (solidBg) headingData.bg = solidBg;
      blocks.push(mkBlock('heading', headingData));
      return;
    }

    if (tag === 'p') {
      const mdText = elInnerToMarkdown(el);
      if (!mdText) return;
      const isItalic = /italic/i.test(style) || el.querySelector('em, i');
      const fontWeight = readStyle(el, 'font-weight');
      const isBold = fontWeight === 'bold' || /^[6-9]00$/.test(fontWeight);

      if (isItalic) {
        flushText();
        blocks.push(mkBlock('quote', { text: mdText.replace(/^["'"]|["'"]$/g, '') }));
      } else if (isBold && mdText.length < 120) {
        flushText();
        blocks.push(mkBlock('pivot', { text: mdText }));
      } else {
        textBuffer.push(mdText);
      }
      return;
    }
  });
  flushText();

  return blocks;
}


/* --------- Toast --------- */
let toastTimer;
function toast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2200);
}

/* --------- Wire global events --------- */
function wireGlobal() {
  // Nav
  document.querySelectorAll('.nav-btn').forEach(b => b.addEventListener('click', () => {
    State.panel = b.dataset.panel;
    renderSide();
  }));

  // Top bar
  document.getElementById('btn-export').addEventListener('click', showFullExportModal);
  document.getElementById('btn-block-export').addEventListener('click', toggleExportSelectMode);
  document.getElementById('ex-copy').addEventListener('click', copyExportSelection);
  document.getElementById('ex-cancel').addEventListener('click', exitExportSelectMode);
  document.getElementById('btn-import').addEventListener('click', showImportModal);
  document.getElementById('btn-preview').addEventListener('click', showPreviewModal);
  document.getElementById('btn-save-as').addEventListener('click', () => {
    const n = prompt('Save this email as:', `Email ${new Date().toLocaleDateString('en-GB')}`);
    if (n && n.trim()) {
      saveCurrentAs(n.trim());
      if (State.panel === 'templates') renderSide();
    }
  });
  document.getElementById('btn-reset').addEventListener('click', () => {
    if (!confirm('Reset everything? This clears the canvas, brand customisations, and saved state. Settings (API keys, brand context) and the GetGround/BA palettes are preserved.')) return;
    const keep = State.settings;
    localStorage.removeItem(STORAGE_KEY);
    // Re-save just the settings so API keys etc. survive
    State.blocks = [];
    State.selectedId = null;
    State.brand = { dark: '#06363A', accent: '#A3ECEE', surface: '#F4FCFD', border: '#D0E8EA', canvas: '#EEF8F9', font: "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif" };
    State.brandProfile = 'getground';
    State.settings = keep;
    save();
    renderCanvas(); renderInspector(); renderSide();
    toast('Reset complete');
  });

  // View toggle. Desktop/Mobile are mutually exclusive; Dark is an independent toggle.
  document.querySelectorAll('.canvas-controls button').forEach(b => b.addEventListener('click', () => {
    const view = b.dataset.view;
    const wrap = document.querySelector('.canvas-wrap');
    if (view === 'dark') {
      b.classList.toggle('active');
      wrap.classList.toggle('dark-preview');
      return;
    }
    // Desktop or mobile: clear those two, then activate this one.
    document.querySelectorAll('.canvas-controls button[data-view="desktop"], .canvas-controls button[data-view="mobile"]').forEach(x => x.classList.remove('active'));
    b.classList.add('active');
    document.getElementById('canvas').classList.toggle('mobile', view === 'mobile');
  }));

  // Canvas clicks
  const canvas = document.getElementById('canvas');
  canvas.addEventListener('click', e => {
    // Stop the click bubbling to the canvas-wrap deselect handler.
    // After we render below, the original target is detached and the wrap
    // handler's closest('.canvas') check would mis-fire.
    e.stopPropagation();

    const anchor = e.target.closest('a');
    if (anchor) {
      e.preventDefault();
    }
    const td = e.target.closest('.canvas-block');
    if (!td) {
      // Clicked inside canvas but outside any block — deselect
      if (State.selectedId) {
        State.selectedId = null;
        renderCanvas();
        renderInspector();
      }
      return;
    }
    const id = td.dataset.blockId;
    // In export-select mode: clicking a top-level block toggles selection.
    // Children inside sections aren't individually selectable.
    if (State.exportMode) {
      e.preventDefault();
      if (td.classList.contains('in-section')) return;
      toggleExportSelected(id);
      return;
    }
    const actBtn = e.target.closest('.block-actions button');
    if (actBtn) {
      e.preventDefault();
      const act = actBtn.dataset.act;
      if (act === 'up') moveBlock(id, -1);
      else if (act === 'down') moveBlock(id, 1);
      else if (act === 'dup') duplicateBlock(id);
      else if (act === 'copy') copyBlockHTML(id);
      else if (act === 'del') deleteBlock(id);
      return;
    }
    selectBlock(id);

    // Click on an image — open the replace dialog directly (sales-friendly).
    const imgTarget = e.target.closest('img[data-img-edit]');
    if (imgTarget) {
      e.preventDefault();
      const found = findBlock(id);
      if (found && found.block) {
        showImageUploadModal(found.block, imgTarget.dataset.imgEdit);
      }
      return;
    }

    // If click landed on an editable text element, start inline edit immediately
    const editTarget = e.target.closest('[data-edit]');
    if (editTarget && !editTarget.isContentEditable) {
      startInlineEdit(editTarget, td);
    }
  });

  // Click outside the canvas (in canvas-wrap area) to deselect
  document.querySelector('.canvas-wrap').addEventListener('click', e => {
    if (e.target.closest('.canvas')) return;       // ignore clicks inside the email
    if (e.target.closest('.canvas-controls')) return;
    if (e.target.closest('.export-bar')) return;
    if (State.selectedId) {
      State.selectedId = null;
      renderCanvas();
      renderInspector();
    }
  });

  // Modal background click
  document.getElementById('modal-bg').addEventListener('click', e => {
    if (e.target.id === 'modal-bg') closeModal();
  });

  // Add-pop close on outside click
  document.getElementById('add-pop-bg').addEventListener('click', e => {
    if (e.target.id === 'add-pop-bg') closeAddPop();
  });

  // ===== Drag-to-add: drop at the position you hover =====
  const canvasWrap = document.querySelector('.canvas-wrap');
  const canvasEl = document.getElementById('canvas');
  const dropInd = document.getElementById('drop-indicator');
  let pendingDropIdx = null;

  // Returns { parentId, index } describing where a block should be inserted.
  // If hovering inside a Section, parentId = section's id and index is within children.
  function calcDropIndex(clientY) {
    // 1. First check if we're inside any Section block
    const sections = canvasEl.querySelectorAll('td.canvas-section');
    let hitSection = null;
    for (const s of sections) {
      const rect = s.getBoundingClientRect();
      if (clientY >= rect.top + 16 && clientY <= rect.bottom - 16) {
        // pad by 16 so dragging at edges drops outside the section
        hitSection = s;
      }
    }
    if (hitSection) {
      const sectionId = hitSection.dataset.blockId;
      const f = findBlock(sectionId);
      if (f) {
        const children = f.block.children || [];
        let idx = children.length;
        for (let i = 0; i < children.length; i++) {
          const childTd = canvasEl.querySelector(`td[data-block-id="${children[i].id}"]`);
          if (!childTd) continue;
          const cr = childTd.getBoundingClientRect();
          if (clientY < cr.top + cr.height / 2) { idx = i; break; }
        }
        return { parentId: sectionId, index: idx };
      }
    }
    // 2. Otherwise, top-level
    let idx = State.blocks.length;
    for (let i = 0; i < State.blocks.length; i++) {
      const td = canvasEl.querySelector(`td[data-block-id="${State.blocks[i].id}"]`);
      if (!td) continue;
      const rect = td.getBoundingClientRect();
      if (clientY < rect.top + rect.height / 2) { idx = i; break; }
    }
    return { parentId: null, index: idx };
  }

  function showDropIndicator(target) {
    if (!target) { dropInd.style.display = 'none'; return; }
    let siblings;
    let containerRect = null;
    if (target.parentId) {
      const f = findBlock(target.parentId);
      if (!f) { dropInd.style.display = 'none'; return; }
      siblings = (f.block.children || []).map(c => canvasEl.querySelector(`td[data-block-id="${c.id}"]`)).filter(Boolean);
      const sectionTd = canvasEl.querySelector(`td[data-block-id="${target.parentId}"]`);
      if (sectionTd) containerRect = sectionTd.getBoundingClientRect();
    } else {
      siblings = State.blocks.map(b => canvasEl.querySelector(`td[data-block-id="${b.id}"]`)).filter(Boolean);
    }
    let rect, top;
    if (siblings.length === 0 && containerRect) {
      // Empty section
      dropInd.style.top = (containerRect.top + 24) + 'px';
      dropInd.style.left = (containerRect.left + 24) + 'px';
      dropInd.style.width = (containerRect.width - 48) + 'px';
      dropInd.style.display = 'block';
      return;
    }
    if (siblings.length === 0) { dropInd.style.display = 'none'; return; }
    if (target.index === 0) { rect = siblings[0].getBoundingClientRect(); top = rect.top - 2; }
    else if (target.index >= siblings.length) { rect = siblings[siblings.length - 1].getBoundingClientRect(); top = rect.bottom - 2; }
    else { rect = siblings[target.index].getBoundingClientRect(); top = rect.top - 2; }
    dropInd.style.top = top + 'px';
    dropInd.style.left = (rect.left + 12) + 'px';
    dropInd.style.width = (rect.width - 24) + 'px';
    dropInd.style.display = 'block';
  }

  function hideDropIndicator() {
    dropInd.style.display = 'none';
  }

  function onDragOver(e) {
    if (!DragState.type && !DragState.fromBlockId) return;
    e.preventDefault();
    e.dataTransfer.dropEffect = DragState.fromBlockId ? 'move' : 'copy';
    canvasEl.classList.add('dragging-over');
    pendingDropIdx = calcDropIndex(e.clientY);
    showDropIndicator(pendingDropIdx);
  }
  // pendingDropIdx is now { parentId, index } object
  function onDragLeave(e) {
    // Only clear if leaving the wrap entirely
    if (e.target === canvasWrap) {
      canvasEl.classList.remove('dragging-over');
      hideDropIndicator();
    }
  }
  function onDrop(e) {
    e.preventDefault();
    canvasEl.classList.remove('dragging-over');
    canvasWrap.classList.remove('dragging');
    hideDropIndicator();
    document.querySelectorAll('.canvas-block.moving').forEach(el => el.classList.remove('moving'));

    // Move existing block?
    if (DragState.fromBlockId) {
      moveBlockToTarget(DragState.fromBlockId, pendingDropIdx);
      DragState.fromBlockId = null;
      DragState.type = null;
      pendingDropIdx = null;
      return;
    }

    // Otherwise: add new block from sidebar
    let type = DragState.type;
    if (!type) {
      try {
        type = e.dataTransfer.getData('application/gg-block') || e.dataTransfer.getData('text/plain');
      } catch(_) {}
    }
    if (type && BlockTypes[type]) {
      const target = pendingDropIdx || { parentId: null, index: null };
      addBlock(type, target.index, target.parentId);
    }
    pendingDropIdx = null;
    DragState.type = null;
  }

  // Drag-handle dragstart on canvas blocks
  canvasEl.addEventListener('dragstart', (e) => {
    const handle = e.target.closest('.drag-handle');
    if (!handle) return;
    const td = handle.closest('.canvas-block');
    if (!td) return;
    const blockId = td.dataset.blockId;
    DragState.fromBlockId = blockId;
    DragState.type = '__move__';
    canvasWrap.classList.add('dragging');
    if (e.dataTransfer) {
      e.dataTransfer.effectAllowed = 'move';
      try { e.dataTransfer.setData('text/plain', '__move__'); } catch(_) {}
    }
    td.classList.add('moving');
  });

  canvasWrap.addEventListener('dragover', onDragOver);
  canvasWrap.addEventListener('dragleave', onDragLeave);
  canvasWrap.addEventListener('drop', onDrop);

  // Hide indicator if drag is cancelled (e.g., dropped outside)
  document.addEventListener('dragend', () => {
    hideDropIndicator();
    canvasEl.classList.remove('dragging-over');
    canvasWrap.classList.remove('dragging');
    document.querySelectorAll('.canvas-block.moving').forEach(el => el.classList.remove('moving'));
    pendingDropIdx = null;
    DragState.fromBlockId = null;
    DragState.type = null;
  });

  // ===== Resizable side panels =====
  function setupResize(handleId, prop, getNewWidth, minW, maxW) {
    const handle = document.getElementById(handleId);
    if (!handle) return;
    handle.addEventListener('mousedown', (e) => {
      e.preventDefault();
      handle.classList.add('dragging');
      document.body.classList.add('resizing');
      const onMove = (ev) => {
        const w = Math.max(minW, Math.min(maxW, getNewWidth(ev)));
        document.documentElement.style.setProperty(prop, w + 'px');
        try {
          const saved = JSON.parse(localStorage.getItem('gg_layout') || '{}');
          saved[prop] = w;
          localStorage.setItem('gg_layout', JSON.stringify(saved));
        } catch {}
      };
      const onUp = () => {
        handle.classList.remove('dragging');
        document.body.classList.remove('resizing');
        document.removeEventListener('mousemove', onMove);
        document.removeEventListener('mouseup', onUp);
      };
      document.addEventListener('mousemove', onMove);
      document.addEventListener('mouseup', onUp);
    });
    // Double-click to reset
    handle.addEventListener('dblclick', () => {
      document.documentElement.style.removeProperty(prop);
      try {
        const saved = JSON.parse(localStorage.getItem('gg_layout') || '{}');
        delete saved[prop];
        localStorage.setItem('gg_layout', JSON.stringify(saved));
      } catch {}
    });
  }
  setupResize('handle-side', '--side-w', (ev) => ev.clientX - 64, 200, 500);
  setupResize('handle-inspector', '--inspector-w', (ev) => window.innerWidth - ev.clientX, 240, 600);

  // Restore saved widths
  try {
    const layout = JSON.parse(localStorage.getItem('gg_layout') || '{}');
    if (layout['--side-w']) document.documentElement.style.setProperty('--side-w', layout['--side-w'] + 'px');
    if (layout['--inspector-w']) document.documentElement.style.setProperty('--inspector-w', layout['--inspector-w'] + 'px');
  } catch {}

  // ===== Inline edit toolbar (B / I / Size) =====
  document.addEventListener('selectionchange', () => maybeShowEditToolbar());
  const editToolbar = document.getElementById('edit-toolbar');
  editToolbar.querySelectorAll('button').forEach(btn => {
    btn.addEventListener('mousedown', (e) => {
      e.preventDefault(); // Keep selection alive
      const fmt = btn.dataset.fmt;
      if (fmt === 'bold' || fmt === 'italic') {
        document.execCommand(fmt);
        return;
      }
      if (fmt === 'link') {
        window.applyInlineLink();
        return;
      }
      if (fmt === 'unlink') {
        document.execCommand('unlink');
        return;
      }
    });
  });

  // Custom size picker (button + dropdown menu). Native <select> steals focus
  // and collapses the contenteditable selection — we avoid that by using a
  // button with preventDefault on mousedown so selection stays alive.
  const sizeBtn = document.getElementById('edit-size-btn');
  const sizeMenu = document.getElementById('edit-size-menu');
  if (sizeBtn && sizeMenu) {
    sizeBtn.addEventListener('mousedown', e => {
      e.preventDefault();
      sizeMenu.classList.toggle('open');
    });
    sizeMenu.querySelectorAll('button[data-size]').forEach(opt => {
      opt.addEventListener('mousedown', e => {
        e.preventDefault();
        const px = parseInt(opt.dataset.size, 10);
        if (!px) return;
        applyExplicitFontSize(px);
        // Reflect chosen size on the trigger button
        sizeBtn.firstChild.textContent = px + ' ';
        sizeMenu.classList.remove('open');
      });
    });
    // Close the menu when clicking outside the picker
    document.addEventListener('mousedown', e => {
      if (!e.target.closest('.edit-size-picker')) {
        sizeMenu.classList.remove('open');
      }
    });
  }

  window.applyInlineLink = function applyInlineLink() {
    const sel = window.getSelection();
    if (!sel.rangeCount || sel.isCollapsed) {
      toast('Select some text first');
      return;
    }
    // If the selection is already inside a link, pre-fill its URL
    let node = sel.anchorNode;
    if (node && node.nodeType === 3) node = node.parentElement;
    const existing = node && node.closest && node.closest('a');
    const existingUrl = existing ? existing.getAttribute('href') : '';
    const url = prompt('Link URL', existingUrl || 'https://');
    if (url === null) return;
    const trimmed = url.trim();
    if (!trimmed || trimmed === 'https://') {
      // Empty — strip any link
      if (existing) document.execCommand('unlink');
      return;
    }
    // Save the selection range, then create the link
    const range = sel.getRangeAt(0);
    const text = range.toString();
    if (!text) return;
    // If selection is inside an existing link, update the href instead of nesting
    if (existing) {
      existing.setAttribute('href', trimmed);
      return;
    }
    // Build the anchor with brand-teal underlined styling
    const a = document.createElement('a');
    a.setAttribute('href', trimmed);
    a.setAttribute('data-gg-link', '1');
    a.style.color = '#06363A';
    a.style.textDecoration = 'underline';
    a.style.fontWeight = '600';
    a.appendChild(document.createTextNode(text));
    range.deleteContents();
    range.insertNode(a);
    // Re-select the link content for follow-up edits
    const newRange = document.createRange();
    newRange.selectNodeContents(a);
    sel.removeAllRanges();
    sel.addRange(newRange);
  }

  // Apply a specific pixel size to the current selection.
  // If selection is already inside a font-size span, update that span;
  // otherwise wrap a fresh span. Either way, no stacking.
  function applyExplicitFontSize(px) {
    const sel = window.getSelection();
    const editingEl = document.querySelector('[contenteditable="true"]');
    // Buttons size the whole label — route to the block's fontSize so it
    // persists cleanly (inline span markers do not survive on a button).
    if (editingEl) {
      const host = editingEl.closest('[data-block-id]');
      const found = host ? findBlock(host.dataset.blockId) : null;
      if (found && found.block && found.block.type === 'button') {
        found.block.fontSize = px;
        const a = editingEl.closest('a');
        if (a) a.style.fontSize = px + 'px';
        save();
        return;
      }
    }
    // If nothing is selected, apply the size to the whole field being edited
    // (so clicking a block and picking a size "just works").
    if (!sel.rangeCount || sel.isCollapsed) {
      if (!editingEl) { toast('Click into some text first'); return; }
      const all = document.createRange();
      all.selectNodeContents(editingEl);
      sel.removeAllRanges();
      sel.addRange(all);
    }
    const range = sel.getRangeAt(0);
    const text = range.toString();
    if (!text) return;
    let node = sel.anchorNode;
    if (node && node.nodeType === 3) node = node.parentElement;
    let sizeSpan = null;
    while (node && node.style && node.tagName !== 'BODY') {
      if (node.style.fontSize) { sizeSpan = node; break; }
      node = node.parentElement;
    }
    if (sizeSpan && sizeSpan.textContent === text) {
      sizeSpan.style.fontSize = px + 'px';
      sizeSpan.style.lineHeight = '1.4';
      const r = document.createRange();
      r.selectNodeContents(sizeSpan);
      sel.removeAllRanges();
      sel.addRange(r);
      persistActiveInlineEdit();
      return;
    }
    range.deleteContents();
    const span = document.createElement('span');
    span.style.fontSize = px + 'px';
    span.style.lineHeight = '1.4';
    span.appendChild(document.createTextNode(text));
    range.insertNode(span);
    const r = document.createRange();
    r.selectNodeContents(span);
    sel.removeAllRanges();
    sel.addRange(r);
    persistActiveInlineEdit();
  }

  function adjustSelectionFontSize(direction) {
    const sel = window.getSelection();
    if (!sel.rangeCount || sel.isCollapsed) return;
    const range = sel.getRangeAt(0);
    const text = range.toString();
    if (!text) return;
    const stops = [10, 12, 14, 16, 18, 20, 24, 28, 32, 40, 48];
    // Try to detect current size from selection's parent
    let node = sel.anchorNode;
    if (node && node.nodeType === 3) node = node.parentElement;
    let currentSize = 16;
    let sizeSpan = null; // the existing span carrying the font-size, if any
    let parent = node;
    while (parent && parent.style) {
      if (parent.style.fontSize) {
        const m = parent.style.fontSize.match(/(\d+)/);
        if (m) { currentSize = Number(m[1]); sizeSpan = parent; break; }
      }
      parent = parent.parentElement;
    }
    let idx = stops.indexOf(currentSize);
    if (idx === -1) {
      // Find nearest
      idx = stops.reduce((acc, v, i) => Math.abs(v - currentSize) < Math.abs(stops[acc] - currentSize) ? i : acc, 0);
    }
    idx = Math.max(0, Math.min(stops.length - 1, idx + direction));
    const newSize = stops[idx];
    // If selection's parent IS a font-size span and the selection covers
    // exactly the span's text, update the span's fontSize in place. Avoids
    // stacking nested spans on repeated A+/A- clicks.
    if (sizeSpan && sizeSpan.textContent === text) {
      sizeSpan.style.fontSize = newSize + 'px';
      sizeSpan.style.lineHeight = '1.4';
      const newRange = document.createRange();
      newRange.selectNodeContents(sizeSpan);
      sel.removeAllRanges();
      sel.addRange(newRange);
      persistActiveInlineEdit();
      return;
    }
    // Otherwise wrap selection in a new span with the new size
    range.deleteContents();
    const span = document.createElement('span');
    span.style.fontSize = newSize + 'px';
    span.style.lineHeight = '1.4';
    span.appendChild(document.createTextNode(text));
    range.insertNode(span);
    // Reselect the span content so further clicks re-adjust the same span
    const newRange = document.createRange();
    newRange.selectNodeContents(span);
    sel.removeAllRanges();
    sel.addRange(newRange);
    persistActiveInlineEdit();
  }

  // Keyboard
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
      closeModal();
      closeAddPop();
      if (State.exportMode) exitExportSelectMode();
      // Also deselect any currently selected block
      if (State.selectedId) {
        State.selectedId = null;
        renderCanvas();
        renderInspector();
      }
    }
    if ((e.metaKey || e.ctrlKey) && e.key === 's') { e.preventDefault(); save(); toast('Saved'); }
    // Block ops shortcuts — skip when typing in form inputs or editing inline.
    const isFormField = e.target && (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA');
    const isContentEditable = e.target && e.target.isContentEditable;
    if (!isFormField && !isContentEditable) {
      // Undo / Redo
      if ((e.metaKey || e.ctrlKey) && !e.shiftKey && (e.key === 'z' || e.key === 'Z')) {
        e.preventDefault(); undo();
      } else if ((e.metaKey || e.ctrlKey) && (e.key === 'y' || e.key === 'Y' || (e.shiftKey && (e.key === 'z' || e.key === 'Z')))) {
        e.preventDefault(); redo();
      }
      // Cmd/Ctrl+D — duplicate selected block
      else if ((e.metaKey || e.ctrlKey) && (e.key === 'd' || e.key === 'D')) {
        if (State.selectedId) {
          e.preventDefault();
          duplicateBlock(State.selectedId);
        }
      }
      // Delete / Backspace — delete selected block
      else if ((e.key === 'Delete' || e.key === 'Backspace') && State.selectedId) {
        e.preventDefault();
        deleteBlock(State.selectedId);
      }
    }
  });

  // ===== Window-level backstop: stop the browser opening dropped files =====
  window.addEventListener('dragover', e => {
    if (e.dataTransfer && e.dataTransfer.types && e.dataTransfer.types.includes('Files')) {
      e.preventDefault();
    }
  });
  window.addEventListener('drop', e => {
    if (e.dataTransfer && e.dataTransfer.types && e.dataTransfer.types.includes('Files')) {
      // Don't preventDefault if we're inside a known drop zone; let it handle
      if (e.target.closest('.img-dropzone') || e.target.closest('#inspector')) return;
      e.preventDefault();
    }
  });

  // ===== Inspector-wide image drop =====
  const inspectorEl = document.getElementById('inspector');
  let inspectorDragCount = 0;

  function getSelectedImageField() {
    const block = State.blocks.find(b => b.id === State.selectedId);
    if (!block) return null;
    const def = BlockTypes[block.type];
    const imageField = def && def.fields.find(fld => fld.type === 'image');
    if (!imageField) return null;
    return { block, key: imageField.key };
  }

  inspectorEl.addEventListener('dragenter', e => {
    if (!e.dataTransfer || !e.dataTransfer.types.includes('Files')) return;
    const ctx = getSelectedImageField();
    if (!ctx) return;
    e.preventDefault();
    inspectorDragCount++;
    inspectorEl.classList.add('drag-target');
  });
  inspectorEl.addEventListener('dragover', e => {
    if (!e.dataTransfer || !e.dataTransfer.types.includes('Files')) return;
    const ctx = getSelectedImageField();
    if (!ctx) return;
    e.preventDefault();
    if (e.dataTransfer) e.dataTransfer.dropEffect = 'copy';
  });
  inspectorEl.addEventListener('dragleave', e => {
    inspectorDragCount = Math.max(0, inspectorDragCount - 1);
    if (inspectorDragCount === 0) inspectorEl.classList.remove('drag-target');
  });
  inspectorEl.addEventListener('drop', async e => {
    inspectorDragCount = 0;
    inspectorEl.classList.remove('drag-target');
    if (!e.dataTransfer || !e.dataTransfer.types.includes('Files')) return;
    const ctx = getSelectedImageField();
    if (!ctx) return;
    e.preventDefault();
    const files = Array.from(e.dataTransfer.files || []);
    const imageFile = files.find(f => f.type.startsWith('image/'));
    if (!imageFile) {
      toast('No image found. Please drop an image file.');
      return;
    }
    await handleImage(imageFile, ctx.block, ctx.key);
  });

  // Paste image from clipboard into the selected block's image field
  document.addEventListener('paste', async (e) => {
    // Don't hijack pastes inside text inputs / textareas (so users can paste text normally)
    const target = e.target;
    if (target && (target.tagName === 'INPUT' || target.tagName === 'TEXTAREA')) {
      // Allow paste into text fields, but if no text is in clipboard but there is an image, still handle
      const types = (e.clipboardData && e.clipboardData.types) || [];
      const hasOnlyImage = types.length && types.every(t => t.startsWith('image/'));
      if (!hasOnlyImage) return;
    }

    const block = State.blocks.find(b => b.id === State.selectedId);
    if (!block) { return; }
    const def = BlockTypes[block.type];
    const imageField = def && def.fields.find(fld => fld.type === 'image');
    if (!imageField) {
      // Selected block has no image field
      const items = e.clipboardData && e.clipboardData.items;
      if (items && Array.from(items).some(i => i.type.startsWith('image/'))) {
        toast('Select an Image or Header block first');
      }
      return;
    }

    const items = e.clipboardData && e.clipboardData.items;
    if (!items) return;
    for (const item of items) {
      if (item.type && item.type.startsWith('image/')) {
        e.preventDefault();
        const file = item.getAsFile();
        if (file) {
          toast('Pasting image…');
          await handleImage(file, block, imageField.key);
        }
        return;
      }
    }
  });
}

/* --------- Boot --------- */
const isFirstVisit = !localStorage.getItem(STORAGE_KEY);
load();

// Auto-load an incoming draft dropped beside the builder (gg-draft.js).
// Loads ONCE per unique draft id, so it never clobbers edits you make later.
try {
  const draft = window.GG_PENDING_DRAFT;
  if (draft && Array.isArray(draft.blocks) && draft.blocks.length) {
    const consumed = localStorage.getItem('gg_draft_consumed');
    if (draft.id && draft.id !== consumed) {
      State.blocks = draft.blocks;
      if (draft.profile && BrandPalettes[draft.profile]) State.brandProfile = draft.profile;
      localStorage.setItem('gg_draft_consumed', draft.id);
      save();
      setTimeout(() => { try { toast('Loaded draft: ' + (draft.name || draft.id)); } catch (e) {} }, 400);
    }
  }
} catch (e) {}

applyEmailWidth();
wireGlobal();

// First-time visitor: pre-load the Welcome email so they have something to look at
if (isFirstVisit && !State.blocks.length) {
  const tpl = Templates.welcome;
  State.blocks = tpl.blocks();
  if (tpl.profile && BrandPalettes[tpl.profile]) State.brandProfile = tpl.profile;
  save();
}

if (State.blocks.some(b => b.type === 'rawhtml')) ensureRawHtmlType();
renderSide();
renderCanvas();
renderInspector();
commitHistory();  // Initial state — gives Cmd+Z something to step back to
</script>

</body>
</html>
